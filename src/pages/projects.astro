---
<Layout title="Selected Work" description="A curated selection of our projects, showcasing our expertise in architectural visualization and interior design. Explore our portfolio to see how we bring spaces to life with stunning CGI renderings and detailed material studies.">

<section class="sw border-b border-white/40" id="selected-work" data-navbar-dark>

  <!-- Custom cursor (pointer devices only) -->
  <div class="sw__cur" id="sw-cur" aria-hidden="true">
    <span class="sw__cur-label" id="sw-cur-label"></span>
  </div>

  <div class="sw__inner">
    <!-- Header: title (left) + search (right) -->
    <div class="sw__header">
      <div class="sw__title-clip">
        <h2 class="sw__title" id="sw-title" aria-label="Projects">
          <span class="sw__t-ghost">PROJECTS</span>
        </h2>
      </div>

      <div class="sw__search" id="sw-search">
        <div class="sw__search-field">
          <input
            type="text"
            class="sw__search-input"
            id="sw-search-input"
            placeholder="SEARCH PROJECT"
            autocomplete="off"
            spellcheck="false"
            aria-label="Search projects"
          />
          <button
            type="button"
            class="sw__search-icon"
            id="sw-search-icon"
            aria-label="Search"
            tabindex="-1"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="8.75" cy="8.75" r="6" stroke="currentColor" stroke-width="1.5" />
              <path d="M13.25 13.25L17.5 17.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Filter chips row -->
    <div class="sw__filters" id="sw-filters" role="group" aria-label="Filter by category">
      {["ALL", "VISUALIZATION", "BRANDING"].map((f, i) => (
        <button
          class={`sw__chip${i === 0 ? " sw__chip--on" : ""}`}
          data-filter={f.toLowerCase()}
          type="button"
        >
          {f}
        </button>
      ))}
    </div>

    <!-- Project rows -->
    <div class="sw__list" id="sw-list">
      <div class="sw__divider sw__divider--top" id="sw-top-divider"></div>

      {projectsList.map((p) => (
        <a
          class="sw__row"
          href={p.href}
          data-project-id={p.id}
          data-categories={p.categories.join(",")}
          data-name={p.title}
          aria-label={p.title}
          data-cursor="view"
        >
          <!-- Inner grid (slides right on hover) -->
          <div class="sw__row-inner">
            <span class="sw__num">{p.num}</span>
            <span class="sw__name">{p.title}</span>
            <span class="sw__tagline">{p.tagline}</span>
            <ul class="sw__tags" aria-hidden="true">
              {p.tags.map((t) => <li class="sw__tag">{t}</li>)}
            </ul>
            <!-- Arrow slides in from left on hover -->
            <span class="sw__arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M3.75 14.25L14.25 3.75M14.25 3.75H6.75M14.25 3.75V11.25"
                  stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>

          <!-- Preview image: absolute inside row, animates scale + rotate on hover -->
          <div class="sw__preview" aria-hidden="true">
            <img src={p.image} alt="" />
          </div>

          <div class="sw__divider sw__divider--row"></div>
        </a>
      ))}

      <!-- Empty state — shown when no project matches the filter/search -->
      <p class="sw__empty" id="sw-empty" hidden>
        No projects match your search.
      </p>
    </div>
  </div>

  <!--
    Apply the URL filter (e.g. /projects?filter=visualization, linked from the
    category "VIEW OUR WORK" CTAs) BEFORE the first paint. Running here, inline
    and synchronously during parse, sets the active chip and collapses the list
    with no flicker/"reload" of the buttons — the GSAP boot then just reads the
    state that is already in the DOM.
  -->
  <script is:inline>
    (function () {
      var requested = (
        new URLSearchParams(location.search).get("filter") || ""
      ).toLowerCase();
      var chips = Array.prototype.slice.call(
        document.querySelectorAll(".sw__chip")
      );
      var valid = chips.some(function (c) {
        return c.dataset.filter === requested;
      });
      var filter = valid ? requested : "all";

      chips.forEach(function (c) {
        c.classList.toggle("sw__chip--on", c.dataset.filter === filter);
      });

      var rows = Array.prototype.slice.call(
        document.querySelectorAll(".sw__row")
      );
      var visible = 0;
      rows.forEach(function (row) {
        var cats = (row.dataset.categories || "").split(",");
        var match = filter === "all" || cats.indexOf(filter) !== -1;
        if (match) {
          row.dataset.hidden = "0";
          visible += 1;
          var numEl = row.querySelector(".sw__num");
          if (numEl) numEl.textContent = String(visible).padStart(2, "0");
        } else {
          row.dataset.hidden = "1";
          row.style.display = "none";
          row.style.pointerEvents = "none";
        }
      });

      var empty = document.getElementById("sw-empty");
      if (empty) empty.hidden = visible > 0;
    })();
  </script>
</section>

</Layout>
<style>
  /* ── Section ── */
  .sw {
    position: relative;
    background: #000000;
    color: #fff;
    cursor: none;
    min-height: 100svh;
  }

  .sw__inner {
    padding: clamp(5rem, 9vw, 12rem) clamp(1.5rem, 2.4vw, 4rem)
      clamp(4rem, 7vw, 10rem);
  }

  /* ── Custom cursor ── */
  .sw__cur {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #fff;
    pointer-events: none;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    will-change: transform, width, height;
    transition:
      width 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
      height 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  @media (pointer: fine) {
    .sw__cur { display: flex; }
  }

  .sw__cur--hover {
    width: 84px;
    height: 84px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
  .sw__cur--down {
    transform: translate(var(--cx, 0), var(--cy, 0)) translate(-50%, -50%) scale(0.85) !important;
  }

  .sw__cur-label {
    font-family: "Poppins", sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    font-weight: 300;
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .sw__cur--hover .sw__cur-label {
    opacity: 1;
  }

  /* ── Header (title + search) ── */
  .sw__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: clamp(1.5rem, 4vw, 4rem);
    /* Margin between header and the filter row (per Figma) */
    padding-bottom: clamp(3.5rem, 6.5vw, 8rem);
  }

  /* ── Search bar ── */
  .sw__search {
    width: clamp(220px, 30vw, 400px);
    align-self: flex-end;
    flex-shrink: 0;
  }
  .sw__search-field {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: clamp(0.45rem, 0.6vw, 0.7rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    transition: border-color 0.25s;
  }
  .sw__search-field:focus-within {
    border-bottom-color: rgba(255, 255, 255, 0.85);
  }
  .sw__search-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    color: #fff;
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.85rem, 1vw, 1.15rem);
    font-weight: 300;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: text;
  }
  .sw__search-input::placeholder {
    color: rgba(255, 255, 255, 0.55);
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 1;
  }
  .sw__search-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 0;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    transition: color 0.25s;
  }
  .sw__search-icon:hover {
    color: #fff;
  }

  /* ── Title ── */
  .sw__title-clip {
    overflow: hidden;
    padding-bottom: 0.04em;
  }
  .sw__title {
    margin: 0;
    font-family: "Poppins", sans-serif;
    font-size: clamp(3.2rem, 9.5vw, 13rem);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.04em;
    white-space: nowrap;
  }
  .sw__t-solid { color: #f6f5f1; }
  .sw__t-ghost { color: rgba(255, 255, 255, 0.19); }
  .sw__title .char {
    color: rgba(255, 255, 255, 0.19);
    display: inline-block;
  }

  /* ── Filter chips ── */
  .sw__filters {
    display: flex;
    gap: clamp(0.4rem, 0.5vw, 0.75rem);
    flex-wrap: wrap;
    justify-content: flex-end;
    /* Margin between the filter row and the projects (per Figma) */
    padding-bottom: clamp(1.1rem, 1.8vw, 2.2rem);
    /* Rendered immediately & stable — no entrance fade. The active chip is set
       pre-paint by the inline script below so it never flickers from ALL → the
       URL filter when arriving via a "VIEW OUR WORK" link. */
  }
  .sw__chip {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.4rem, 0.5vw, 0.75rem);
    padding: clamp(0.4rem, 0.5vw, 0.65rem) clamp(0.8rem, 1vw, 1.2rem);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 999px;
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.58rem, 0.72vw, 0.9rem);
    font-weight: 300;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    transition: all 0.25s;
    cursor: none;
  }
  .sw__chip:hover:not(.sw__chip--on) {
    border-color: rgba(255, 255, 255, 0.7);
    color: #fff;
  }
  .sw__chip--on {
    background: #fff;
    color: #000;
    border-color: #fff;
  }

  /* ── Dividers ── */
  .sw__divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    pointer-events: none;
  }
  .sw__divider--top {
    transform: scaleX(0);
    transform-origin: left center;
  }
  .sw__divider--row {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
  }

  /* ── Row ── */
  .sw__row {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
    cursor: none;
    /* Rows start hidden for entrance animation */
    opacity: 0;
    transform: translateY(18px);
  }

  /* Inner grid — slides right on hover */
  .sw__row-inner {
    display: grid;
    grid-template-columns:
      clamp(2.2rem, 4vw, 5rem)       /* num */
      clamp(9rem, 24vw, 30rem)       /* name */
      clamp(7rem, 17vw, 24rem)       /* tagline */
      1fr                            /* spacer */
      auto                           /* tags */
      2.5rem;                        /* arrow */
    align-items: center;
    column-gap: clamp(1rem, 2vw, 2.5rem);
    padding: clamp(1.1rem, 2.3vw, 3rem) 0;
    position: relative;
    z-index: 2;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .sw__row.is-hover .sw__row-inner {
    transform: translateX(16px);
  }

  /* Columns */
  .sw__num {
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.78rem, 1vw, 1.3rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.42);
  }
  .sw__name {
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.95rem, 1.3vw, 1.7rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    white-space: nowrap;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sw__tagline {
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.78rem, 1vw, 1.3rem);
    font-style: italic;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.42);
    min-width: 0;
  }
  .sw__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: clamp(0.3rem, 0.4vw, 0.55rem);
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .sw__tag {
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: clamp(0.2rem, 0.28vw, 0.4rem) clamp(0.55rem, 0.75vw, 1rem);
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.58rem, 0.7vw, 0.88rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.48);
    white-space: nowrap;
    font-style: normal;
  }

  /* Arrow — slides in from left on hover */
  .sw__arrow {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    opacity: 0;
    transform: translateX(-12px);
    transition:
      opacity 0.3s cubic-bezier(0.2, 0.8, 0.2, 1),
      transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    color: rgba(255, 255, 255, 0.8);
  }
  .sw__row.is-hover .sw__arrow {
    opacity: 1;
    transform: translateX(2px);
  }

  /* ── Preview image — absolute in row ── */
  .sw__preview {
    position: absolute;
    top: 50%;
    right: 30%;
    transform: translate(0, -50%) scale(0.88) rotate(-3deg);
    width: clamp(160px, 15vw, 280px);
    aspect-ratio: 3 / 2;
    border: 1px solid rgba(255, 255, 255, 0.12);
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
      transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 1;
  }
  .sw__preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sw__row.is-hover .sw__preview {
    opacity: 1;
    transform: translate(0, -50%) scale(1.06) rotate(-2deg);
    pointer-events: auto;
  }
  .sw__row.is-hover .sw__preview:hover {
    transform: translate(0, -50%) scale(1.14) rotate(-1deg);
  }

  /* ── Empty state ── */
  .sw__empty {
    margin: 0;
    padding: clamp(2.5rem, 6vw, 5rem) 0;
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.9rem, 1.1vw, 1.25rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.5);
    text-align: center;
  }
  .sw__empty[hidden] {
    display: none;
  }

  /* ── MOBILE & TABLET (≤1024px) — Figma "PROYECTOS INTERIOR" listing ──
     Rows show num + name + tags (no tagline / hover preview / arrow);
     big number, smaller name & tags; touch = no custom cursor. */
  @media (max-width: 1024px) {
    .sw { cursor: auto; }
    .sw__cur { display: none !important; }

    /* clear the fixed navbar + roomier side gutters */
    .sw__inner {
      padding: clamp(8rem, 22vw, 11rem) clamp(2.4rem, 6vw, 4rem)
        clamp(4rem, 10vw, 8rem);
    }

    /* header: title, then search, stacked full-width */
    .sw__header {
      flex-direction: column;
      align-items: stretch;
      gap: clamp(1.4rem, 6vw, 2.4rem);
      /* Big airy gap between search and filters.
         Figma "PROJECTS INTERIOR MOBILE" (591px frame): search underline y=327,
         filter chips y=566 → 239px gap ≈ 40.4vw. */
      padding-bottom: clamp(8rem, 40vw, 18rem);
    }
    .sw__search {
      width: 100%;
      align-self: stretch;
    }
    /* Search text/placeholder = 24px in Figma (591px frame) */
    .sw__search-input {
      font-size: clamp(1.05rem, 4.06vw, 1.5rem);
    }
    .sw__filters {
      justify-content: flex-end;
      opacity: 1;
      gap: clamp(0.6rem, 1.8vw, 1rem);
      padding-bottom: clamp(0.7rem, 2vw, 1.2rem);
    }
    .sw__chip {
      /* Figma chip label = 12px (591px frame) */
      font-size: clamp(0.7rem, 2.03vw, 0.75rem);
      padding: clamp(0.6rem, 1.8vw, 0.9rem) clamp(1.1rem, 3.2vw, 1.6rem);
      letter-spacing: 0.08em;
    }

    /* rows: num | name | tags */
    .sw__row-inner {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: clamp(1rem, 3vw, 2rem);
      align-items: center;
      padding: clamp(1.2rem, 3.2vw, 2.2rem) 0;
    }
    .sw__tagline,
    .sw__arrow,
    .sw__preview { display: none; }
    .sw__tags { display: flex; }

    /* Font sizes from Figma "PROJECTS INTERIOR MOBILE" (591px frame):
       title 64px, num 24px, name 12px, tag 10px. vw calibrated to 591px,
       capped at the Figma px, with readable floors for small phones. */
    .sw__title { font-size: clamp(2.6rem, 10.8vw, 4rem); }
    .sw__num { font-size: clamp(1.1rem, 4.06vw, 1.5rem); }
    .sw__name { font-size: clamp(0.7rem, 2.03vw, 0.75rem); white-space: normal; }
    .sw__tag { font-size: clamp(0.58rem, 1.69vw, 0.625rem); }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(ScrollTrigger, SplitText);

  // ── Custom cursor ─────────────────────────────────────────────────

  function initCursor() {
    if (typeof window === "undefined") return;
    if (!window.matchMedia("(pointer: fine)").matches) return;

    const curMaybe = document.getElementById("sw-cur") as HTMLElement | null;
    const labelMaybe = document.getElementById("sw-cur-label") as HTMLElement | null;
    const section = document.getElementById("selected-work") as HTMLElement | null;
    if (!curMaybe || !labelMaybe || !section) return;

    // Reassign to non-nullable so nested functions keep the narrowing
    const cur: HTMLElement = curMaybe;
    const label: HTMLElement = labelMaybe;
    let down = false;

    function setCursorPos(x: number, y: number) {
      cur.style.transform = `translate(${x}px, ${y}px) translate(-50%, -50%) scale(${down ? 0.85 : 1})`;
    }

    window.addEventListener("mousemove", (e) => setCursorPos(e.clientX, e.clientY), { passive: true });
    window.addEventListener("mousedown", () => { down = true; });
    window.addEventListener("mouseup", () => { down = false; });

    section.addEventListener("mouseenter", () => { cur.style.display = "flex"; });
    section.addEventListener("mouseleave", () => {
      cur.style.display = "none";
      cur.classList.remove("sw__cur--hover");
      label.textContent = "";
    });
  }

  // ── Row hover (CSS does the animation, JS toggles class) ─────────

  function initRows() {
    const cur = document.getElementById("sw-cur") as HTMLElement | null;
    const label = document.getElementById("sw-cur-label") as HTMLElement | null;
    const rows = Array.from(document.querySelectorAll<HTMLElement>(".sw__row"));

    rows.forEach((row) => {
      row.addEventListener("mouseenter", () => {
        row.classList.add("is-hover");
        cur?.classList.add("sw__cur--hover");
        if (label) label.textContent = "VIEW";
      });
      row.addEventListener("mouseleave", () => {
        row.classList.remove("is-hover");
        cur?.classList.remove("sw__cur--hover");
        if (label) label.textContent = "";
      });
    });
  }

  // ── Filter chips + search ────────────────────────────────────────
  //
  // A row is visible only when it matches BOTH the active category chip
  // AND the search query. Non-matching rows are removed from the flow
  // (display:none) so the matching ones collapse up to the top. When no
  // row matches, an empty-state message is shown.

  function initFiltersAndSearch() {
    const chips = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".sw__chip")
    );
    const rows = Array.from(document.querySelectorAll<HTMLElement>(".sw__row"));
    const searchInput = document.getElementById(
      "sw-search-input"
    ) as HTMLInputElement | null;
    const searchIcon = document.getElementById("sw-search-icon");
    const emptyEl = document.getElementById("sw-empty") as HTMLElement | null;

    // Initial state was already applied pre-paint by the inline script, so read
    // the active filter back from the highlighted chip instead of recomputing.
    let activeFilter =
      (document.querySelector(".sw__chip--on") as HTMLElement | null)?.dataset
        .filter ?? "all";

    const norm = (s: string) =>
      s
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .trim();

    function renumber() {
      let n = 0;
      rows.forEach((row) => {
        if (row.dataset.hidden === "1") return;
        n += 1;
        const numEl = row.querySelector<HTMLElement>(".sw__num");
        if (numEl) numEl.textContent = String(n).padStart(2, "0");
      });
    }

    function showRow(row: HTMLElement, index: number) {
      const wasHidden = row.dataset.hidden === "1";
      row.dataset.hidden = "0";
      row.style.display = "";
      row.style.pointerEvents = "auto";
      gsap.killTweensOf(row);
      if (wasHidden) {
        gsap.fromTo(
          row,
          { opacity: 0, y: 8 },
          {
            opacity: 1,
            y: 0,
            duration: 0.4,
            ease: "power2.out",
            delay: index * 0.04,
          }
        );
      } else {
        gsap.to(row, { opacity: 1, y: 0, duration: 0.3, ease: "power2.out" });
      }
    }

    function hideRow(row: HTMLElement) {
      if (row.dataset.hidden === "1") return;
      row.dataset.hidden = "1";
      row.style.pointerEvents = "none";
      row.classList.remove("is-hover");
      gsap.killTweensOf(row);
      gsap.to(row, {
        opacity: 0,
        duration: 0.25,
        ease: "power2.in",
        onComplete: () => {
          if (row.dataset.hidden === "1") row.style.display = "none";
        },
      });
    }

    function applyView() {
      const query = searchInput ? norm(searchInput.value) : "";
      let visibleIndex = 0;

      rows.forEach((row) => {
        const cats = row.dataset.categories?.split(",") ?? [];
        const name = norm(row.dataset.name ?? "");
        const matchesFilter =
          activeFilter === "all" || cats.includes(activeFilter);
        const matchesSearch = query === "" || name.includes(query);

        if (matchesFilter && matchesSearch) {
          showRow(row, visibleIndex);
          visibleIndex += 1;
        } else {
          hideRow(row);
        }
      });

      if (emptyEl) emptyEl.hidden = visibleIndex > 0;
      renumber();
    }

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        activeFilter = chip.dataset.filter ?? "all";
        chips.forEach((c) => c.classList.remove("sw__chip--on"));
        chip.classList.add("sw__chip--on");
        applyView();
      });
    });

    if (searchInput) {
      searchInput.addEventListener("input", applyView);
    }
    if (searchIcon && searchInput) {
      searchIcon.addEventListener("click", () => searchInput.focus());
    }
  }

  // ── Hide the custom cursor over the search field ─────────────────

  function initSearchCursor() {
    if (!window.matchMedia("(pointer: fine)").matches) return;
    const cur = document.getElementById("sw-cur") as HTMLElement | null;
    const search = document.getElementById("sw-search") as HTMLElement | null;
    if (!cur || !search) return;
    search.addEventListener("mouseenter", () => {
      cur.style.display = "none";
    });
    search.addEventListener("mouseleave", () => {
      cur.style.display = "flex";
    });
  }

  // ── Entrance animations (GSAP ScrollTrigger) ─────────────────────

  function initEntrance() {
    const section = document.getElementById("selected-work");
    const title = document.getElementById("sw-title");
    const topDivider = document.getElementById("sw-top-divider");
    // Skip rows already hidden by an initial URL filter so the entrance only
    // reveals the matching ones.
    const rows = gsap.utils
      .toArray<HTMLElement>(".sw__row")
      .filter((row) => row.dataset.hidden !== "1");

    if (!section || !title) return;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 72%",
      },
    });

    // Divider draws in left→right
    if (topDivider) {
      tl.to(topDivider, {
        scaleX: 1,
        duration: 0.85,
        ease: "power3.inOut",
      });
    }

    // Title chars reveal left→right, same effect as Cover.astro h1
    const split = new SplitText(title, { type: "chars", charsClass: "char" });
    tl.to(
      split.chars,
      { color: "white", duration: 0.1, stagger: { each: 0.07, from: "start" }, ease: "none" },
      "-=0.5"
    );

    // Search bar + filter chips are rendered immediately (stable, no entrance
    // fade) so they never look like they "reload" on load — see the inline
    // pre-paint script and the .sw__search / .sw__filters styles.

    // Rows stagger in
    tl.to(
      rows,
      { opacity: 1, y: 0, duration: 0.6, ease: "power2.out", stagger: 0.09 },
      "-=0.4"
    );
  }

  // ── Boot ─────────────────────────────────────────────────────────

  function boot() {
    initCursor();
    initSearchCursor();
    initRows();
    initFiltersAndSearch();
    initEntrance();
  }

  if ((window as any).lenisReady) {
    boot();
  } else {
    window.addEventListener("lenis:ready", boot, { once: true });
  }
</script>
