---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import NavbarInterior from "../../components/helpers/NavbarInterior.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const all = (await getCollection("projects")).sort(
    (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
      a.data.order - b.data.order,
  );
  return all.map((project: CollectionEntry<"projects">, i: number) => ({
    params: { slug: project.id, },
    props: { project, next: all[(i + 1) % all.length] },
  }));
}

type Props = {
  project: CollectionEntry<"projects">;
  next: CollectionEntry<"projects">;
};

const { project, next } = Astro.props;
const d = project.data;
const imgs = d.images;
const narrative = project.body.trim();
---

<Layout showChrome={false}>
  <!-- Transition mask: white wipe that reveals on enter / covers on exit -->
  <div class="pd-mask" id="pd-mask" aria-hidden="true"></div>

  <div class="pd">
    <NavbarInterior />

    <!-- ──────────────────────────────────────────────────────────────
         HERO SECTION
    ─────────────────────────────────────────────────────────────── -->
    <section class="pd-hero">
      <div class="pd-line" id="pd-line-top"></div>

      <div class="pd-hero__content">
        <div class="pd-hero__clip">
          <h1 class="pd-hero__title" id="pd-title">{d.title}</h1>
        </div>

        <div class="pd-hero__meta" id="pd-meta">
          <!-- LEFT: Discipline + Scope -->
          <div class="pd-hero__meta-left">
            <p class="pd-meta__label">Discipline</p>
            <p class="pd-meta__value">{d.discipline}</p>
            <p class="pd-meta__label pd-meta__label--mt">Scope</p>
            <p class="pd-meta__value">{d.scope}</p>
          </div>
          <!-- RIGHT: Client (optional) + Description -->
          <div class="pd-hero__meta-right">
            {d.client && (
              <>
                <p class="pd-meta__label pd-meta__label--right">Client</p>
                <p class="pd-meta__value pd-meta__value--right">{d.client}</p>
                <div style="height:1.2rem"></div>
              </>
            )}
            <p class="pd-meta__label pd-meta__label--right">Description</p>
            <p class="pd-meta__value pd-meta__value--right">{d.description}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Full-width hero image -->
    <div class="pd-img pd-img--hero pd-par">
      <img src={imgs[0]} alt={d.title} loading="eager" decoding="async" />
    </div>

    <!-- Split: image left + narrative right -->
    <div class="pd-split" data-reveal>
      <div class="pd-split__img pd-par">
        <img src={imgs[1]} alt={d.title} loading="lazy" decoding="async" />
      </div>
      <div class="pd-split__text">
        <p class="pd-section-label">Project Narrative</p>
        <p class="pd-section-body">{narrative}</p>
      </div>
    </div>

    <!-- Duo: two equal images -->
    <div class="pd-duo" data-reveal>
      <div class="pd-par">
        <img src={imgs[2]} alt={d.title} loading="lazy" decoding="async" />
      </div>
      <div class="pd-par">
        <img src={imgs[3]} alt={d.title} loading="lazy" decoding="async" />
      </div>
    </div>

    <!-- pd2 + pd3: full-width 4th image -->
    {(d.layout === "pd2" || d.layout === "pd3") && imgs[4] && (
      <div class="pd-img pd-img--full pd-par" data-reveal>
        <img src={imgs[4]} alt={d.title} loading="lazy" decoding="async" />
      </div>
    )}

    <!-- pd2 only: portrait (left) + closing line (lower right) -->
    {d.layout === "pd2" && imgs[5] && (
      <div class="pd-portrait-row" data-reveal>
        <div class="pd-par pd-par--portrait">
          <img src={imgs[5]} alt={d.title} loading="lazy" decoding="async" />
        </div>
        <div class="pd-portrait-closing">
          <p class="pd-section-label pd-section-label--right">Closing Line</p>
          <p class="pd-section-body pd-section-body--right">{d.closingLine}</p>
        </div>
      </div>
    )}

    <!-- pd1 + pd3: closing line as separate right-aligned section -->
    {(d.layout === "pd1" || d.layout === "pd3") && (
      <div class="pd-closing" data-reveal>
        <div class="pd-closing__inner">
          <p class="pd-section-label pd-section-label--right">Closing Line</p>
          <p class="pd-section-body pd-section-body--right">{d.closingLine}</p>
        </div>
      </div>
    )}

    <!-- ──────────────────────────────────────────────────────────────
         NEXT PROJECT — 300svh pin zone
         Page pins → progress bar fills → next page rises from below
    ─────────────────────────────────────────────────────────────── -->
    <section class="pd-next" id="pd-next-section">
      <!-- Sticky: sticks to viewport top for the full 300svh duration -->
      <div class="pd-next__pin">

        <!-- Progress bar: fills left→right as you scroll through the pin -->
        <div class="pd-next__progress" aria-hidden="true">
          <div class="pd-next__progress-bg"></div>
          <div class="pd-next__progress-fill" id="pd-progress-fill"></div>
        </div>

        <!-- NEXT PROJECT header — visible on the white background -->
        <div class="pd-next__head">
          <span class="pd-next__label" id="pd-next-label">NEXT PROJECT</span>
          <a
            href={`/works/${next.id}/`}
            class="pd-next__title"
            id="pd-next-link"
            data-next-href={`/works/${next.id}/`}
          >{next.data.title}</a>
        </div>

        <!-- The rising "page below" — slides up from translateY(100%) to 0% -->
        <a
          href={`/works/${next.id}/`}
          class="pd-next__cover"
          id="pd-next-cover"
          data-next-href={`/works/${next.id}/`}
          aria-label={`Go to ${next.data.title}`}
        >
          <img
            src={next.data.images[0]}
            alt={next.data.title}
            class="pd-next__cover-img"
            loading="lazy"
            decoding="async"
          />
          <div class="pd-next__cover-overlay"></div>
          <div class="pd-next__cover-info">
            <span class="pd-next__cover-label">NEXT PROJECT</span>
            <p class="pd-next__cover-title">{next.data.title}</p>
          </div>
        </a>

      </div>
    </section>

    <Footer />
  </div>
</Layout>

<style>
  /* ── Mask — starts opaque white, fades out on enter (studiodado pattern) ── */
  .pd-mask {
    position: fixed;
    inset: 0;
    background: #fff;
    z-index: 9999;
    pointer-events: none;
  }

  /* ── Page wrapper ── */
  .pd { background: #fff; color: #000; min-height: 100svh; }

  /* ── Horizontal lines ── */
  .pd-line {
    height: 1px;
    background: rgba(0, 0, 0, 0.15);
    transform: scaleX(0);
    transform-origin: left center;
  }

  /* ── HERO ────────────────────────────────────────────────────── */
  .pd-hero {
    padding: clamp(8rem, 12vh, 11rem) clamp(1.2rem, 3.3vw, 4.5rem) 0;
  }

  .pd-hero__content { padding-top: clamp(1.2rem, 2.5vw, 3.5rem); }

  .pd-hero__clip { overflow: hidden; padding-bottom: 0.06em; }

  .pd-hero__title {
    margin: 0;
    font-family: "Poppins", sans-serif;
    font-size: clamp(2.4rem, 4.8vw, 7rem);
    font-weight: 300;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: #000;
    text-transform: uppercase;
    transform: translateY(110%);
    opacity: 0;
  }

  .pd-hero__meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 8rem);
    padding: clamp(1rem, 2vw, 2.5rem) 0 clamp(2.5rem, 4vw, 6rem);
    opacity: 0;
    transform: translateY(14px);
  }

  .pd-meta__label {
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.9rem, 1.05vw, 1.35rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 0.3rem;
    color: #000;
  }
  .pd-meta__label--mt { margin-top: 1.4rem; }
  .pd-meta__label--right { text-align: right; }

  .pd-meta__value {
    font-family: "Poppins", sans-serif;
    font-size: clamp(1rem, 1.25vw, 1.5rem);
    font-weight: 300;
    line-height: 1.55;
    color: #333;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .pd-meta__value--right { text-align: right; }

  .pd-hero__meta-right { display: flex; flex-direction: column; align-items: flex-end; }

  /* ── PARALLAX wrapper ── */
  .pd-par { overflow: hidden; }
  .pd-par img {
    width: 100%;
    height: 116%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: translateY(-8%);
    will-change: transform;
  }

  /* ── HERO IMAGE ── */
  .pd-img--hero { height: clamp(50vh, 70svh, 88svh); }

  /* ── SPLIT SECTION ── */
  .pd-split {
    display: grid;
    grid-template-columns: 52fr 48fr;
    gap: clamp(1.5rem, 2.5vw, 4rem);
    padding: clamp(2rem, 4vw, 7rem) clamp(1.2rem, 3.3vw, 4.5rem) 0;
    align-items: center;
  }

  .pd-split__img { height: clamp(320px, 50svh, 700px); }

  .pd-split__text {
    padding: clamp(1rem, 2vw, 3rem) 0;
    opacity: 0;
    transform: translateY(24px);
  }

  /* ── DUO SECTION ── */
  .pd-duo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(0.5rem, 1.5vw, 2rem);
    padding: clamp(1.5rem, 3vw, 5rem) clamp(1.2rem, 3.3vw, 4.5rem) 0;
  }
  .pd-duo .pd-par { height: clamp(260px, 40svh, 600px); }

  /* ── FULL-WIDTH 4th image (pd2, pd3) ── */
  .pd-img--full {
    height: clamp(50vh, 68svh, 85svh);
    margin-top: clamp(1.5rem, 3vw, 5rem);
  }

  /* ── PORTRAIT + CLOSING row (pd2) ── */
  .pd-portrait-row {
    display: grid;
    grid-template-columns: 45fr 55fr;
    gap: clamp(1rem, 2vw, 3rem);
    padding: clamp(1.5rem, 3vw, 5rem) clamp(1.2rem, 3.3vw, 4.5rem) 0;
    align-items: end;
  }

  .pd-par--portrait { height: clamp(450px, 62svh, 900px); }

  .pd-portrait-closing {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: clamp(1.5rem, 3vw, 4rem);
    opacity: 0;
    transform: translateY(24px);
  }

  /* ── CLOSING SECTION (pd1, pd3) ── */
  .pd-closing {
    padding: clamp(3rem, 6vw, 9rem) clamp(1.2rem, 3.3vw, 4.5rem) 0;
    display: flex;
    justify-content: flex-end;
  }
  .pd-closing__inner {
    max-width: clamp(280px, 32vw, 500px);
    opacity: 0;
    transform: translateY(20px);
  }

  /* ── SECTION TEXT ── */
  .pd-section-label {
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.9rem, 1.05vw, 1.35rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.9rem;
    color: #000;
  }
  .pd-section-label--right { text-align: right; }

  .pd-section-body {
    font-family: "Poppins", sans-serif;
    font-size: clamp(1.05rem, 1.35vw, 1.6rem);
    font-weight: 300;
    line-height: 1.75;
    color: #333;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .pd-section-body--right { text-align: right; }

  /* ── NEXT PROJECT — 300svh pin zone ───────────────────────────── */

  /* Outer section: tall enough for the full pin scroll */
  .pd-next {
    height: 300svh;
    position: relative;
    margin-top: clamp(4rem, 8vw, 12rem);
  }

  /* Sticky container: sticks to top for the entire 300svh pin */
  .pd-next__pin {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    background: #fff;
  }

  /* ── Progress bar (thin line at top — fills left → right) ── */
  .pd-next__progress {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 10;
  }
  .pd-next__progress-bg {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.1);
  }
  .pd-next__progress-fill {
    position: absolute;
    inset: 0;
    background: #000;
    transform: scaleX(0);
    transform-origin: left center;
    will-change: transform;
  }

  /* ── Header: NEXT PROJECT label + large title ── */
  .pd-next__head {
    position: absolute;
    top: clamp(2rem, 4vw, 5rem);
    left: clamp(1.2rem, 3.3vw, 4.5rem);
    right: clamp(1.2rem, 3.3vw, 4.5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1.2vw, 1.5rem);
    pointer-events: none;
  }

  .pd-next__label {
    display: block;
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.9rem, 1.05vw, 1.35rem);
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    opacity: 0;
    transform: translateY(12px);
  }

  .pd-next__title {
    font-family: "Poppins", sans-serif;
    font-size: clamp(2.4rem, 4.8vw, 7rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #000;
    text-decoration: none;
    line-height: 1.02;
    display: block;
    text-align: right;
    opacity: 0;
    transform: translateY(20px);
    pointer-events: auto;
    cursor: pointer;
  }
  .pd-next__title:hover { opacity: 0.5 !important; transition: opacity 0.2s; }

  /* ── Rising cover: the "page below" — starts fully below viewport ── */
  .pd-next__cover {
    position: absolute;
    inset: 0;
    transform: translateY(100%);
    will-change: transform;
    display: block;
    text-decoration: none;
    cursor: pointer;
  }

  .pd-next__cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pd-next__cover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.38);
    pointer-events: none;
  }

  .pd-next__cover-info {
    position: absolute;
    bottom: clamp(2rem, 5vw, 6rem);
    left: clamp(1.2rem, 3.3vw, 4.5rem);
    color: #fff;
    pointer-events: none;
  }
  .pd-next__cover-label {
    display: block;
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.9rem, 1.05vw, 1.35rem);
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
    opacity: 0.72;
  }
  .pd-next__cover-title {
    font-family: "Poppins", sans-serif;
    font-size: clamp(2.4rem, 4.8vw, 7rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.02;
  }

  /* ── MOBILE ── */
  @media (max-width: 700px) {
    .pd-hero__meta,
    .pd-split,
    .pd-duo,
    .pd-portrait-row { grid-template-columns: 1fr; }

    .pd-split__img,
    .pd-duo .pd-par,
    .pd-par--portrait { height: clamp(220px, 55vw, 420px); }

    .pd-hero__meta-right { align-items: flex-start; }
    .pd-meta__label--right,
    .pd-meta__value--right,
    .pd-section-label--right,
    .pd-section-body--right { text-align: left; }
    .pd-next__title { text-align: left; }
    .pd-closing { justify-content: flex-start; }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ─────────────────────────────────────────────────────────────────
  // ENTER ANIMATION — studiodado exact pattern:
  //   mask (white, starts opaque) fades out in 0.5s power1
  //   hero line, title, meta all start at t=0 simultaneously
  //   hero image scales from 1.05→1 as mask reveals it
  // ─────────────────────────────────────────────────────────────────

  function initEnter() {
    const mask    = document.getElementById("pd-mask") as HTMLElement | null;
    const lineTop = document.getElementById("pd-line-top");
    const title   = document.getElementById("pd-title");
    const meta    = document.getElementById("pd-meta");
    const heroImg = document.querySelector<HTMLElement>(".pd-img--hero img");

    // Mask starts opaque by CSS — fade it out 0.5s power1 (studiodado exact)
    const tl = gsap.timeline();

    if (mask)
      tl.fromTo(mask,
        { opacity: 1, visibility: "visible" },
        { opacity: 0, duration: 0.5, ease: "power1",
          onComplete() { mask.style.display = "none"; } },
        0,
      );

    // Hero image: slight scale-out as mask reveals (studiodado: scale 1.1→1)
    if (heroImg)
      tl.from(heroImg, { scale: 1.06, duration: 1.0, ease: "power3.out" }, 0);

    // Separator line
    if (lineTop)
      tl.to(lineTop, { scaleX: 1, duration: 0.7, ease: "power3.inOut" }, 0);

    // Title (studiodado: y:80→0, power3, duration:1.25)
    if (title)
      tl.to(title, { y: "0%", opacity: 1, duration: 1.1, ease: "expo.out" }, 0.08);

    // Meta row (studiodado: y:80→0, power3, stagger:0.1, duration:1.25)
    if (meta)
      tl.to(meta, { y: 0, opacity: 1, duration: 0.9, ease: "power3.out" }, 0.22);
  }

  // ─────────────────────────────────────────────────────────────────
  // LEAVE ANIMATION — studiodado exact pattern:
  //   mask fades from 0→1 (power1, 0.5s)
  //   onComplete → scroll reset to 0 → navigate
  // ─────────────────────────────────────────────────────────────────

  let isNavigating = false;

  function navigateTo(href: string) {
    if (isNavigating) return;
    isNavigating = true;

    const mask = document.getElementById("pd-mask") as HTMLElement | null;
    if (!mask) { window.location.href = href; return; }

    // Bring mask back: visible but transparent
    mask.style.display = "block";
    mask.style.visibility = "visible";

    gsap.fromTo(mask,
      { opacity: 0 },
      {
        opacity: 1,
        duration: 0.5,
        ease: "power1",
        onComplete() {
          // Hidden behind white — safe to reset scroll (studiodado pattern)
          if ((window as any).lenis) (window as any).lenis.scrollTo(0, { immediate: true });
          window.scrollTo(0, 0);
          window.location.href = href;
        },
      },
    );
  }

  // ─────────────────────────────────────────────────────────────────
  // PARALLAX on all .pd-par images
  // ─────────────────────────────────────────────────────────────────

  function initParallax() {
    document.querySelectorAll<HTMLElement>(".pd-par").forEach((wrap) => {
      const img = wrap.querySelector<HTMLElement>("img");
      if (!img) return;
      gsap.fromTo(img,
        { yPercent: -8 },
        {
          yPercent: 8,
          ease: "none",
          scrollTrigger: {
            trigger: wrap,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        },
      );
    });
  }

  // ─────────────────────────────────────────────────────────────────
  // SCROLL REVEAL — images + text blocks (content sections only)
  // ─────────────────────────────────────────────────────────────────

  function initReveal() {
    document.querySelectorAll<HTMLElement>(
      "[data-reveal] .pd-par, .pd-img--full",
    ).forEach((el) => {
      gsap.from(el, {
        opacity: 0, y: 45, duration: 1.1, ease: "power3.out",
        scrollTrigger: { trigger: el, start: "top 88%" },
      });
    });

    document.querySelectorAll<HTMLElement>(
      ".pd-split__text, .pd-closing__inner, .pd-portrait-closing",
    ).forEach((el) => {
      gsap.to(el, {
        y: 0, opacity: 1, duration: 1.0, ease: "power3.out",
        scrollTrigger: { trigger: el, start: "top 84%" },
      });
    });
  }

  // ─────────────────────────────────────────────────────────────────
  // NEXT PROJECT pin zone
  //   - section is 300svh, inner div is sticky (CSS pin)
  //   - ScrollTrigger scrubs: progress bar + label + title + rising cover
  //   - start: "top top"  end: "bottom bottom"  scrub: true
  //   - at progress >= 0.99 → navigateTo
  // ─────────────────────────────────────────────────────────────────

  function initNextSection() {
    const section     = document.getElementById("pd-next-section");
    const fill        = document.getElementById("pd-progress-fill");
    const cover       = document.getElementById("pd-next-cover") as HTMLElement | null;
    const label       = document.getElementById("pd-next-label");
    const title       = document.querySelector<HTMLElement>(".pd-next__title");
    if (!section || !fill || !cover) return;

    const nextHref = cover.dataset.nextHref!;
    let triggered = false;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top top",      // pin activates when section hits viewport top
        end: "bottom bottom",  // stays pinned until section bottom passes viewport bottom
        scrub: true,           // 1-to-1 scroll mapping (no lag)
        onUpdate(self) {
          if (self.progress >= 0.99 && !triggered) {
            triggered = true;
            navigateTo(nextHref);
          }
        },
      },
    });

    // 1. Progress bar fills left→right (full duration, linear)
    tl.to(fill, { scaleX: 1, ease: "none", duration: 1 }, 0);

    // 2. "NEXT PROJECT" label fades + rises (quick, at scroll start)
    if (label) tl.to(label, { opacity: 1, y: 0, duration: 0.15, ease: "power3.out" }, 0);

    // 3. Next project title fades + rises (quick)
    if (title) tl.to(title, { opacity: 1, y: 0, duration: 0.15, ease: "expo.out" }, 0.04);

    // 4. Cover rises from below — the "page under the other" effect
    //    Starts slightly after label appears, covers full viewport by end
    tl.to(cover, { y: "0%", ease: "none", duration: 0.8 }, 0.18);

    // Click handler on cover (in case user clicks before 99%)
    cover.addEventListener("click", (e) => {
      e.preventDefault();
      if (!triggered) { triggered = true; navigateTo(nextHref); }
    });

    // Also intercept the text title link
    const titleLink = document.getElementById("pd-next-link") as HTMLAnchorElement | null;
    if (titleLink) {
      titleLink.addEventListener("click", (e) => {
        e.preventDefault();
        if (!triggered) { triggered = true; navigateTo(nextHref); }
      });
    }
  }

  // ─────────────────────────────────────────────────────────────────
  // BOOT
  // ─────────────────────────────────────────────────────────────────

  function boot() {
    initEnter();
    initParallax();
    initReveal();
    initNextSection();
  }

  if ((window as any).lenisReady) {
    boot();
  } else {
    window.addEventListener("lenis:ready", boot, { once: true });
  }
</script>
