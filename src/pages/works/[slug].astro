---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import NavbarInterior from "../../components/helpers/NavbarInterior.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const all = (await getCollection("projects")).sort(
    (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
      a.data.order - b.data.order,
  );
  return all.map((project: CollectionEntry<"projects">, i: number) => ({
    params: { slug: project.id.toLowerCase(), },
    props: { project, next: all[(i + 1) % all.length] },
  }));
}

type Props = {
  project: CollectionEntry<"projects">;
  next: CollectionEntry<"projects">;
};

const { project, next } = Astro.props;
const d = project.data;
const imgs = d.images;
const narrative = project.body.trim();
---

<Layout showChrome={false}>
  <div class="pd">
    <NavbarInterior />

    <!-- ──────────────────────────────────────────────────────────────
         HERO SECTION
    ─────────────────────────────────────────────────────────────── -->
    <section class="pd-hero">
      <div class="pd-line" id="pd-line-top"></div>

      <div class="pd-hero__content">
        <div class="pd-hero__clip">
          <h1 class="pd-hero__title" id="pd-title">{d.title}</h1>
        </div>

        <!-- Hero image — sits between the title and the meta on mobile/tablet
             (Figma order); on desktop CSS `order` pushes it below the meta.
             The vertical-pictures template has no hero image (Figma frame). -->
        {!d.verticalLayout && (
          <div class="pd-img pd-img--hero pd-par">
            <img src={imgs[0]} alt={d.title} loading="eager" decoding="async" />
          </div>
        )}

        <div class="pd-hero__meta" id="pd-meta">
          <!-- LEFT: Discipline + Scope -->
          <div class="pd-hero__meta-left">
            <p class="pd-meta__label">Discipline</p>
            <p class="pd-meta__value">{d.discipline}</p>
            <p class="pd-meta__label pd-meta__label--mt">Scope</p>
            <p class="pd-meta__value">{d.scope}</p>
          </div>
          <!-- RIGHT: Client (optional) + Description -->
          <div class="pd-hero__meta-right">
            {d.client && (
              <>
                <p class="pd-meta__label pd-meta__label--right">Client</p>
                <p class="pd-meta__value pd-meta__value--right">{d.client}</p>
                <div style="height:1.2rem"></div>
              </>
            )}
            <p class="pd-meta__label pd-meta__label--right">Description</p>
            <p class="pd-meta__value pd-meta__value--right">{d.description}</p>
          </div>
        </div>
      </div>
    </section>

    {d.verticalLayout ? (
      <>
        {/* ── VERTICAL PICTURES template (Figma "project vertical pictures") ──
             Portrait images. Always opens with a pair side by side, then a
             single + narrative, then a single + closing line. */}

        {/* Block A: two portrait images side by side — ALWAYS the opener */}
        {imgs[0] && imgs[1] && (
          <div class="pdv-duo" data-reveal>
            <div class="pd-par pdv-img">
              <img src={imgs[0]} alt={d.title} loading="eager" decoding="async" />
            </div>
            <div class="pd-par pdv-img">
              <img src={imgs[1]} alt={d.title} loading="eager" decoding="async" />
            </div>
          </div>
        )}

        {/* Block B: portrait image (left) + Project Narrative (right) */}
        <div class="pdv-row pdv-row--narrative" data-reveal>
          {imgs[2] && (
            <div class="pd-par pdv-img">
              <img src={imgs[2]} alt={d.title} loading="lazy" decoding="async" />
            </div>
          )}
          <div class="pdv-text">
            <p class="pd-section-label">Project Narrative</p>
            <p class="pd-section-body">{narrative}</p>
          </div>
        </div>

        {/* Block C: portrait image (left) + Closing Line (lower right) */}
        <div class="pdv-row pdv-row--closing" data-reveal>
          {imgs[3] && (
            <div class="pd-par pdv-img">
              <img src={imgs[3]} alt={d.title} loading="lazy" decoding="async" />
            </div>
          )}
          <div class="pdv-text pdv-text--closing">
            <p class="pd-section-label pd-section-label--right">Closing Line</p>
            <p class="pd-section-body pd-section-body--right">{d.closingLine}</p>
          </div>
        </div>
      </>
    ) : (
      <>
        {/* Split: image left + narrative right */}
        <div class="pd-split" data-reveal>
          <div class="pd-split__img pd-par">
            <img src={imgs[1]} alt={d.title} loading="lazy" decoding="async" />
          </div>
          <div class="pd-split__text">
            <p class="pd-section-label">Project Narrative</p>
            <p class="pd-section-body">{narrative}</p>
          </div>
        </div>

        {/* Duo: two equal images */}
        <div class="pd-duo" data-reveal>
          <div class="pd-par">
            <img src={imgs[2]} alt={d.title} loading="lazy" decoding="async" />
          </div>
          <div class="pd-par">
            <img src={imgs[3]} alt={d.title} loading="lazy" decoding="async" />
          </div>
        </div>

        {/* pd2 + pd3: full-width 4th image. A pd3 vertical image is paired
            with the closing line below instead of rendering full-width here. */}
        {(d.layout === "pd2" || (d.layout === "pd3" && !d.fullImageVertical)) && imgs[4] && (
          <div
            class:list={["pd-img", "pd-img--full", "pd-par", { "pd-img--full--portrait": d.fullImageVertical }]}
            data-reveal
          >
            <img src={imgs[4]} alt={d.title} loading="lazy" decoding="async" />
          </div>
        )}

        {/* pd3 + vertical full image: portrait photo (left) + closing line
            (right), placed in parallel. The 1fr 1fr pd-portrait-row keeps the
            image edge aligned with the duo/split columns above. */}
        {d.layout === "pd3" && d.fullImageVertical && imgs[4] && (
          <div class="pd-portrait-row" data-reveal>
            <div class="pd-par pd-par--portrait">
              <img src={imgs[4]} alt={d.title} loading="lazy" decoding="async" />
            </div>
            <div class="pd-portrait-closing">
              <p class="pd-section-label pd-section-label--right">Closing Line</p>
              <p class="pd-section-body pd-section-body--right">{d.closingLine}</p>
            </div>
          </div>
        )}

        {/* pd2 only: portrait (left) + closing line (lower right) */}
        {d.layout === "pd2" && imgs[5] && (
          <div class="pd-portrait-row" data-reveal>
            <div class="pd-par pd-par--portrait">
              <img src={imgs[5]} alt={d.title} loading="lazy" decoding="async" />
            </div>
            <div class="pd-portrait-closing">
              <p class="pd-section-label pd-section-label--right">Closing Line</p>
              <p class="pd-section-body pd-section-body--right">{d.closingLine}</p>
            </div>
          </div>
        )}

        {/* pd1 + pd3 (non-vertical): closing line as separate right-aligned
            section. The pd3 vertical case renders it beside the photo above. */}
        {(d.layout === "pd1" || (d.layout === "pd3" && !d.fullImageVertical)) && (
          <div class="pd-closing" data-reveal>
            <div class="pd-closing__inner">
              <p class="pd-section-label pd-section-label--right">Closing Line</p>
              <p class="pd-section-body pd-section-body--right">{d.closingLine}</p>
            </div>
          </div>
        )}
      </>
    )}

    <!-- ──────────────────────────────────────────────────────────────
         NEXT PROJECT — 300svh pin zone (studiodado pattern)
         Page pins → progress bar fills (ease-out) → auto-navigate at end.
         Shows a static preview: label (left) + title (right) + image below.
    ─────────────────────────────────────────────────────────────── -->
    <section class="pd-next" id="pd-next-section">
      <!-- Sticky: sticks to viewport top for the full 300svh duration -->
      <div class="pd-next__pin">
        <a
          href={`/works/${next.id.toLowerCase()}/`}
          class="pd-next__link"
          id="pd-next-link"
          data-next-href={`/works/${next.id.toLowerCase()}/`}
          aria-label={`Go to ${next.data.title}`}
        >
          <!-- Progress bar: fills left→right as you scroll through the pin -->
          <div class="pd-next__progress" aria-hidden="true">
            <div class="pd-next__progress-bg"></div>
            <div class="pd-next__progress-fill" id="pd-progress-fill"></div>
          </div>

          <!-- Header: label (left) + title (right) -->
          <div class="pd-next__head">
            <span class="pd-next__label" id="pd-next-label">NEXT PROJECT</span>
            <h2 class="pd-next__title">{next.data.title}</h2>
          </div>

          <!-- Static preview image — fills remaining height, cropped by fold -->
          <div class="pd-next__media">
            <img
              src={next.data.images[0]}
              alt={next.data.title}
              class="pd-next__media-img"
              loading="lazy"
              decoding="async"
            />
          </div>
        </a>
      </div>
    </section>

    <Footer />
  </div>
</Layout>

<style>
  /* ── Page wrapper ── */
  .pd {
    background: #fff;
    color: #000;
    min-height: 100svh;
    padding-inline: clamp(2.4rem, 3.3vw, 4.5rem);
  }

  /* ── Horizontal lines ── */
  .pd-line {
    height: 1px;
    background: rgba(0, 0, 0, 0.15);
    transform: scaleX(0);
    transform-origin: left center;
  }

  /* ── HERO ────────────────────────────────────────────────────── */
  .pd-hero {
    padding: clamp(8rem, 12vh, 11rem) 0 0;
  }

  .pd-hero__content {
    padding-top: clamp(1.2rem, 2.5vw, 3.5rem);
    display: flex;
    flex-direction: column;
  }

  .pd-hero__clip { overflow: hidden; padding-bottom: 0.06em; }

  .pd-hero__title {
    margin: 0;
    font-family: "Poppins", sans-serif;
    font-size: clamp(2.4rem, 4.8vw, 7rem);
    font-weight: 300;
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: #000;
    text-transform: uppercase;
    transform: translateY(110%);
    opacity: 0;
  }

  .pd-hero__meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 8rem);
    padding: clamp(1rem, 2vw, 2.5rem) 0 clamp(2.5rem, 4vw, 6rem);
    opacity: 0;
    transform: translateY(14px);
  }

  .pd-meta__label {
    font-family: "Poppins", sans-serif;
    font-size: clamp(1.05rem, 1.25vw, 1.6rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 0.3rem;
    color: #000;
  }
  .pd-meta__label--mt { margin-top: 1.4rem; }
  .pd-meta__label--right { text-align: right; }

  .pd-meta__value {
    font-family: "Poppins", sans-serif;
    font-size: clamp(1rem, 1.25vw, 1.5rem);
    font-weight: 300;
    line-height: 1.55;
    color: #333;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .pd-meta__value--right { text-align: right; }

  .pd-hero__meta-right { display: flex; flex-direction: column; align-items: flex-end; }

  /* ── PARALLAX wrapper ── */
  .pd-par { overflow: hidden; }
  .pd-par img {
    width: 100%;
    height: 100%;
    display: block;
    will-change: transform;
  }

  /* ── HERO IMAGE — now lives inside .pd-hero__content (gets its side
     padding from .pd-hero). On desktop `order` drops it below the meta. ── */
  .pd-img--hero {}
  @media (min-width: 768px) {
    .pd-hero__meta { order: 1; }
    .pd-img--hero { order: 2; }
  }

  /* ── SPLIT SECTION ── */
  .pd-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 2.5vw, 4rem);
    padding: clamp(2rem, 4vw, 7rem) 0 0;
    align-items: center;
  }

  .pd-split__img {}

  .pd-split__text {
    padding: clamp(1rem, 2vw, 3rem) 0;
    opacity: 0;
    transform: translateY(24px);
  }

  /* ── DUO SECTION ── */
  .pd-duo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 2.5vw, 4rem);
    padding: clamp(1.5rem, 3vw, 5rem) 0 0;
  }
  .pd-duo .pd-par {}

  /* ── FULL-WIDTH 4th image (pd2, pd3) ── */
  .pd-img--full {
    margin-top: clamp(1.5rem, 3vw, 5rem);
  }
  /* Vertical/portrait full image → ~half width, centered, keeps its aspect
     instead of stretching full-bleed across the screen. */
  .pd-img--full--portrait {
    width: clamp(280px, 46%, 720px);
    margin-inline: 0 auto;
  }

  /* ── PORTRAIT + CLOSING row (pd2) ── */
  .pd-portrait-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 3rem);
    padding: clamp(1.5rem, 3vw, 5rem) 0 0;
    align-items: end;
  }

  .pd-par--portrait {}

  .pd-portrait-closing {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: clamp(1.5rem, 3vw, 4rem);
    opacity: 0;
    transform: translateY(24px);
  }

  /* ── CLOSING SECTION (pd1, pd3) ── */
  .pd-closing {
    padding: clamp(3rem, 6vw, 9rem) 0 0;
    display: flex;
    justify-content: flex-end;
  }
  .pd-closing__inner {
    max-width: clamp(280px, 32vw, 500px);
    opacity: 0;
    transform: translateY(20px);
  }

  /* ── VERTICAL PICTURES template (Figma "project vertical pictures") ──
     Portrait images at ~half width; text sits beside them. Image wrappers
     keep the source's natural (tall) aspect via .pd-par img { height:auto }. */
  .pdv-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 6rem);
    padding: clamp(2rem, 4vw, 7rem) 0 0;
  }
  .pdv-row--narrative { align-items: center; }
  .pdv-row--closing { align-items: end; }

  .pdv-duo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 6rem);
    padding: clamp(1.5rem, 3vw, 5rem) 0 0;
  }

  .pdv-text {
    opacity: 0;
    transform: translateY(24px);
  }
  .pdv-text--closing {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: clamp(1.5rem, 3vw, 4rem);
  }

  /* ── SECTION TEXT ── */
  .pd-section-label {
    font-family: "Poppins", sans-serif;
    font-size: clamp(1.05rem, 1.25vw, 1.6rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.9rem;
    color: #000;
  }
  .pd-section-label--right { text-align: right; }

  .pd-section-body {
    font-family: "Poppins", sans-serif;
    font-size: clamp(1.05rem, 1.35vw, 1.6rem);
    font-weight: 300;
    line-height: 1.75;
    color: #333;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .pd-section-body--right { text-align: right; }

  /* ── NEXT PROJECT — 300svh pin zone ───────────────────────────── */

  /* Outer section: tall enough for the full pin scroll */
  .pd-next {
    height: 300svh;
    position: relative;
    margin-top: clamp(4rem, 8vw, 12rem);
    margin-inline: calc(-1 * clamp(2.4rem, 3.3vw, 4.5rem));
  }

  /* Sticky container: sticks to top for the entire 300svh pin */
  .pd-next__pin {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    background: #fff;
  }

  /* The whole preview is one link: progress + header + image */
  .pd-next__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    cursor: pointer;
    padding: clamp(7rem, 13vh, 11rem) clamp(1.2rem, 3.3vw, 4.5rem) 0;
  }

  /* ── Progress bar (thin line — fills left → right) ── */
  .pd-next__progress {
    position: relative;
    width: 100%;
    height: 1px;
    flex: none;
  }
  .pd-next__progress-bg {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.1);
  }
  .pd-next__progress-fill {
    position: absolute;
    inset: 0;
    background: #000;
    transform: scaleX(0);
    transform-origin: left center;
    will-change: transform;
  }

  /* ── Header: label (left) + large title (right) ── */
  .pd-next__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    gap: clamp(1rem, 4vw, 6rem);
    padding: clamp(1.5rem, 3vw, 3rem) 0 0;
    flex: none;
  }

  .pd-next__label {
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.9rem, 1.05vw, 1.35rem);
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    margin: 0;
    opacity: 0;
    transform: translateY(12px);
  }

  .pd-next__title {
    font-family: "Poppins", sans-serif;
    font-size: clamp(2.4rem, 4.8vw, 7rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #000;
    line-height: 1.02;
    margin: 0;
    text-align: right;
    opacity: 0;
    transform: translateY(20px);
  }

  /* ── Static preview image — fills remaining height, cropped by fold ── */
  .pd-next__media {
    flex: 1 1 auto;
    min-height: 0;
    margin-top: clamp(1.5rem, 4vw, 4rem);
    overflow: hidden;
  }
  .pd-next__media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    opacity: 0;
    will-change: transform;
  }

  /* Hover (whole link) — only once the preview has revealed (.is-ready) */
  .pd-next__link.is-ready:hover .pd-next__title { opacity: 0.5; transition: opacity 0.3s; }
  .pd-next__link.is-ready:hover .pd-next__media-img { transform: scale(1.03); transition: transform 0.7s ease; }

  /* ── TABLET (768–1024px) — same multi-column layout as desktop, only the
     sizes are tuned down so it fits the narrower viewport (NOT the mobile
     single-column stack). ── */
  @media (min-width: 768px) and (max-width: 1024px) {
    /* Roomier side gutters for the fixed navbar + comfortable margins */
    .pd { padding-inline: clamp(2rem, 4vw, 3rem); }

    /* Title scales with viewport but a touch larger than the pure vw clamp */
    .pd-hero__title { font-size: clamp(3rem, 6vw, 4.6rem); }

    /* Meta: keep the two-column grid, tighten the gap, more space from title */
    .pd-hero__meta { gap: clamp(1.5rem, 3.5vw, 3rem); margin-top: clamp(1.8rem, 5vw, 3rem); }
    .pd-meta__label,
    .pd-section-label { font-size: clamp(1rem, 1.7vw, 1.3rem); }
    .pd-meta__value,
    .pd-section-body { font-size: clamp(0.95rem, 1.6vw, 1.25rem); }

    /* Next project title scaled to match the hero */
    .pd-next__title { font-size: clamp(3rem, 6vw, 4.6rem); }
  }

  /* ── MOBILE (≤767px) — single-column stack (Figma INTERIOR PROYECTOS) ──
     Order: title → hero image → meta. Body text ~20px (labels = values),
     all images landscape (~16:9), looser vertical rhythm. */
  @media (max-width: 767px) {
    .pd-hero__meta,
    .pd-split,
    .pd-duo,
    .pd-portrait-row,
    .pdv-row,
    .pdv-duo,
    .pd-next__head { grid-template-columns: 1fr; }

    /* Title — Figma 32px */
    .pd-hero__title { font-size: clamp(2.2rem, 5.6vw, 3.6rem); }

    /* Hero image — natural aspect (no crop), with breathing room */
    .pd-img--hero {
      height: auto;
      aspect-ratio: auto;
      margin: clamp(1.6rem, 4vw, 2.6rem) 0 clamp(2rem, 5vw, 3.2rem);
    }

    /* Meta — stacked, left-aligned, with a pronounced gap below the title */
    .pd-hero__meta {
      gap: clamp(1.4rem, 3.6vw, 2.2rem);
      margin-top: clamp(1.6rem, 6vw, 2.4rem);
      padding-top: 0;
      padding-bottom: 0;
    }
    .pd-hero__meta-right { align-items: flex-start; }
    .pd-meta__label--right,
    .pd-meta__value--right,
    .pd-section-label--right,
    .pd-section-body--right { text-align: left; }

    /* Body text → Figma's ~20px (labels = values, bold vs regular) */
    .pd-meta__label,
    .pd-section-label { font-size: clamp(1.3rem, 3.3vw, 1.85rem); }
    .pd-meta__value,
    .pd-section-body { font-size: clamp(1.3rem, 3.3vw, 1.85rem); line-height: 1.55; }

    /* All content images show their FULL content on mobile — natural aspect,
       no vertical cropping. */
    .pd-img--hero,
    .pd-split__img,
    .pd-duo .pd-par,
    .pd-par--portrait,
    .pd-img--full,
    .pdv-img { aspect-ratio: auto; }
    .pd-par img { height: auto; object-fit: contain; }

    /* portrait full image: full-width on mobile, keeps its natural aspect */
    .pd-img--full--portrait { width: 100%; aspect-ratio: auto; }
    .pd-img--full--portrait img { height: auto; object-fit: contain; }

    /* vertical-pictures spacing — looser stacked rhythm */
    .pdv-row,
    .pdv-duo { padding-top: clamp(1.8rem, 4vw, 2.8rem); gap: clamp(1.4rem, 4vw, 2.4rem); }
    .pdv-text--closing { padding-bottom: 0; }

    /* Section spacing — looser so blocks breathe */
    .pd-split { padding-top: clamp(2.6rem, 6vw, 4rem); gap: clamp(1.4rem, 4vw, 2.4rem); }
    .pd-duo { padding-top: clamp(1.8rem, 4vw, 2.8rem); gap: clamp(1.2rem, 3vw, 2rem); }
    .pd-img--full { margin-top: clamp(1.8rem, 4vw, 2.8rem); }
    .pd-portrait-row { padding-top: clamp(1.8rem, 4vw, 2.8rem); gap: clamp(1.6rem, 4vw, 2.4rem); }
    .pd-portrait-closing { padding-bottom: 0; }
    .pd-closing { padding-top: clamp(2.6rem, 6vw, 4rem); justify-content: flex-start; }

    /* Next project */
    .pd-next__head { gap: clamp(0.8rem, 3vw, 1.6rem); }
    .pd-next__title { text-align: left; font-size: clamp(2.2rem, 5.6vw, 3.6rem); }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { navigate } from "astro:transitions/client";

  gsap.registerPlugin(ScrollTrigger);

  let enterTl: gsap.core.Timeline | null = null;

  // ─────────────────────────────────────────────────────────────────
  // ENTER ANIMATION — hero separator line + title rise + meta fade in.
  // The page-to-page cross-fade is handled natively by <ClientRouter />.
  // ─────────────────────────────────────────────────────────────────

  function initEnter() {
    const lineTop = document.getElementById("pd-line-top");
    const title   = document.getElementById("pd-title");
    const meta    = document.getElementById("pd-meta");

    enterTl = gsap.timeline();

    // Separator line
    if (lineTop)
      enterTl.to(lineTop, { scaleX: 1, duration: 0.7, ease: "power3.inOut" }, 0);

    // Title rises into view
    if (title)
      enterTl.to(title, { y: "0%", opacity: 1, duration: 1.1, ease: "expo.out" }, 0.08);

    // Meta row fades in
    if (meta)
      enterTl.to(meta, { y: 0, opacity: 1, duration: 0.9, ease: "power3.out" }, 0.22);
  }

  // ─────────────────────────────────────────────────────────────────
  // PARALLAX on all .pd-par images
  // ─────────────────────────────────────────────────────────────────

  function initParallax() {
    document.querySelectorAll<HTMLElement>(".pd-par").forEach((wrap) => {
      const img = wrap.querySelector<HTMLElement>("img");
      if (!img) return;
      gsap.fromTo(img,
        { scale: 1.12, yPercent: -5 },
        {
          scale: 1.12,
          yPercent: 5,
          ease: "none",
          scrollTrigger: {
            trigger: wrap,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        },
      );
    });
  }

  // ─────────────────────────────────────────────────────────────────
  // SCROLL REVEAL — images + text blocks (content sections only)
  // ─────────────────────────────────────────────────────────────────

  function initReveal() {
    document.querySelectorAll<HTMLElement>(
      ".pd-split__text, .pd-closing__inner, .pd-portrait-closing, .pdv-text",
    ).forEach((el) => {
      gsap.to(el, {
        y: 0, opacity: 1, duration: 1.0, ease: "power3.out",
        scrollTrigger: { trigger: el, start: "top 84%" },
      });
    });
  }

  // ─────────────────────────────────────────────────────────────────
  // NEXT PROJECT pin zone (studiodado pattern)
  //   - section is 300svh, inner div is sticky (CSS pin)
  //   - label + title + image reveal ONCE when the section scrolls in
  //   - progress bar fills with ease-out as you scroll the pin (scrub)
  //   - at progress >= 0.99 → navigate() (soft View Transition, no reload)
  // ─────────────────────────────────────────────────────────────────

  function initNextSection() {
    const section = document.getElementById("pd-next-section");
    const fill    = document.getElementById("pd-progress-fill");
    const link    = document.getElementById("pd-next-link") as HTMLAnchorElement | null;
    const label   = document.getElementById("pd-next-label");
    const title   = document.querySelector<HTMLElement>(".pd-next__title");
    const media   = document.querySelector<HTMLElement>(".pd-next__media-img");
    if (!section || !fill || !link) return;

    const nextHref = link.dataset.nextHref!;
    let triggered = false;

    // One-time reveal of the preview (label + title + image) when it scrolls in.
    // Hover is only enabled once this finishes (.is-ready).
    const reveal = gsap.timeline({
      scrollTrigger: { trigger: section, start: "top 70%" },
      onComplete() { link.classList.add("is-ready"); },
    });
    if (media) reveal.fromTo(media, { opacity: 0 }, { opacity: 1, duration: 1.1, ease: "power2.out" }, 0);
    if (label) reveal.to(label, { opacity: 1, y: 0, duration: 0.7, ease: "power3.out" }, 0.05);
    if (title) reveal.to(title, { opacity: 1, y: 0, duration: 0.9, ease: "expo.out" }, 0.12);

    // Progress bar fills as you scroll the pin — ease-out (studiodado: 1-(1-p)²).
    // With scrub, the tween's ease maps scroll progress → scaleX.
    gsap.to(fill, {
      scaleX: 1,
      ease: "power2.out",
      scrollTrigger: {
        trigger: section,
        start: "top top",      // pin activates when section hits viewport top
        end: "bottom bottom",  // stays pinned until section bottom passes viewport bottom
        scrub: true,           // 1-to-1 scroll mapping (no lag)
        onUpdate(self) {
          if (self.progress >= 0.99 && !triggered) {
            triggered = true;
            navigate(nextHref);   // soft, no-reload View Transition
          }
        },
      },
    });

    // Click anywhere on the preview → soft navigate (View Transition)
    link.addEventListener("click", (e) => {
      e.preventDefault();
      if (!triggered) { triggered = true; navigate(nextHref); }
    });
  }

  // ─────────────────────────────────────────────────────────────────
  // LIFECYCLE — re-init on every (soft) navigation, clean up before leaving.
  // <ClientRouter /> keeps the JS runtime alive, so module scripts run ONCE;
  // all setup must hang off astro:page-load and tear down on astro:before-swap,
  // otherwise stale ScrollTriggers pile up and the next page never animates.
  // ─────────────────────────────────────────────────────────────────

  function init() {
    initEnter();
    initParallax();
    initReveal();
    initNextSection();
    ScrollTrigger.refresh();
  }

  function cleanup() {
    enterTl?.kill();
    enterTl = null;
    ScrollTrigger.getAll().forEach((t) => t.kill());
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-swap", cleanup);
</script>
