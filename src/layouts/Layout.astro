---
import "../styles/global.css";
import "lenis/dist/lenis.css";
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
	showChrome?: boolean;
}

const { showChrome = true } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Borsoga Studio</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,200;0,300;0,600;0,700&display=swap"
			rel="stylesheet"
		/>
		<ClientRouter />
	</head>
	<body>
		{showChrome && <Navbar />}
		<slot />
		{showChrome && <Footer />}
	</body>
</html>

<style>
	html,
	body {
		background-color: #f7f7f7;
		margin: 0;
		width: 100%;
		/* NOT height:100% — that locks the body to one viewport tall, so content
		   overflows the box and (on iOS Safari, with its dynamic toolbars) bleeds
		   above/below the visual viewport. Let height grow with content. */
		min-height: 100%;
		/* `clip` (not `hidden`) — clips horizontal overflow WITHOUT creating a
		   scroll container, so it doesn't break `position: sticky` descendants. */
		overflow-x: clip;
	}
	/* Stop iOS Safari rubber-band overscroll from exposing content past the edges */
	html {
		overscroll-behavior-y: none;
	}
</style>

<script>
	import Lenis from "lenis";
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	declare global {
		interface Window {
			lenis: Lenis | null;
		}
	}

	gsap.registerPlugin(ScrollTrigger);

	let lenis: Lenis | null = null;
	let rafId: number | null = null;

	function initLenis() {
		if (lenis) {
			gsap.ticker.remove(rafId as unknown as gsap.Callback);
			lenis.destroy();
			lenis = null;
			rafId = null;
		}

		lenis = new Lenis({
			duration: 1.2,
			easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
			smoothWheel: true,
			wheelMultiplier: 1.2,
			touchMultiplier: 1,
			// autoRaf: false — we drive it manually via GSAP ticker
			autoRaf: false,
		});

		window.lenis = lenis;

		// Every Lenis tick → ScrollTrigger evaluates all triggers against current scrollY
		lenis.on("scroll", ScrollTrigger.update);

		// Signal to components that Lenis is ready
		(window as any).lenisReady = true;
		window.dispatchEvent(new CustomEvent("lenis:ready"));

		// GSAP ticker drives Lenis RAF
		const ticker = (time: number) => {
			lenis!.raf(time * 1000);
		};
		rafId = ticker as unknown as number;
		gsap.ticker.add(ticker);
		gsap.ticker.lagSmoothing(0);
	}

	// With <ClientRouter /> active, astro:page-load fires on the initial load
	// AND after every soft navigation — so a single listener covers both.
	// (A bare initLenis() here too would double-init and break components that
	// listen for lenis:ready with { once: true }.)
	document.addEventListener("astro:page-load", initLenis);

	// Scope soft (no-reload) View Transitions to project → project only.
	// The GSAP-heavy home & /projects pages run their scroll setup once on
	// load, so any soft navigation into/out of them would leave them broken.
	// Mark every link as a full reload EXCEPT the "next project" link.
	function markReloadLinks() {
		document
			.querySelectorAll<HTMLAnchorElement>("a[href]")
			.forEach((a) => {
				if (a.id === "pd-next-link") return; // the only soft-nav link
				a.setAttribute("data-astro-reload", "");
			});
	}
	document.addEventListener("astro:page-load", markReloadLinks);
</script>
