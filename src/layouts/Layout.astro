---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Borsoga Studio</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,200;0,300;0,600;0,700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		background-color: #f7f7f7;
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>

<script>
	import Lenis from "lenis";
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	declare global {
		interface Window { lenis: Lenis | null; }
	}

	gsap.registerPlugin(ScrollTrigger);

	let lenis: Lenis | null = null;
	let rafId: number | null = null;

	function initLenis() {
		// Cleanup anterior
		if (lenis) {
			gsap.ticker.remove(rafId as unknown as gsap.Callback);
			lenis.destroy();
			lenis = null;
			rafId = null;
		}

		lenis = new Lenis({
			duration: 1.2,
			easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
			lerp: 0.1,
			smoothWheel: true,
			wheelMultiplier: 1.2,
			touchMultiplier: 1,
		});

		window.lenis = lenis;

		lenis.on("scroll", ScrollTrigger.update);

		const ticker = (time: number) => { lenis!.raf(time * 1000); };
		rafId = ticker as unknown as number;
		gsap.ticker.add(ticker);
		gsap.ticker.lagSmoothing(0);
	}

	initLenis();

	document.addEventListener("astro:page-load", initLenis);
</script>
