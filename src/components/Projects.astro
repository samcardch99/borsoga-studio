---
import { getCollection, type CollectionEntry } from "astro:content";

type Project = CollectionEntry<"projects">;

// Homepage preview — only a handful of projects (5 visualization + 1 brand
// identity). Ordered explicitly so the preview always reads the same way
// regardless of the collection's global `order`.
const FEATURED = [
  "RAL-1011-FIVE-PARK-APARTMENT", // viz
  "RAL-8003-WOOD-VEIN-KITCHEN-CLOSET", // viz
  "RAL-9002-CORNER-RESIDENTIAL-BUILDING", // viz
  "RAL-7006-COCONUT-GROVE-RESIDENCE", // viz
  "RAL-1013-CRYSTAL-RIVER-RESIDENCE", // viz
  "RAL-9005-REFRAME", // brand
];

const raw = await getCollection("projects");
// Collection ids are slugified to lowercase, so match case-insensitively.
const byId = new Map(raw.map((p: Project) => [p.id.toLowerCase(), p]));
const projects = FEATURED.map((id) => byId.get(id.toLowerCase()))
  .filter((p): p is Project => Boolean(p))
  .map((p: Project) => ({
    uid: p.id,
    title: p.data.title,
    href: `/works/${p.id}/`,
    thumb: p.data.images[0],
  }));
---

<section id="selected-work" class="projects section border-b border-black">
  <!-- ───────────── DESKTOP (≥1025px) — Figma "Projects Exterior" ─────────────
       Image stack flush against the LEFT viewport edge, heading + sticky title
       list + CTA right-aligned on the right. -->
  <div class="projects__container projects__desktop">
    <div class="projects__grid">
      <!-- LEFT — image stack (flush-left) -->
      <div class="projects__wrapper" data-animation="gallery">
        {
          projects.map((p, i) => (
            <div
              class="projects__item projects__item--primary"
              data-project-index={i}
            >
              <a
                class="projects__item-link"
                href={p.href}
                aria-label={`See ${p.title}`}
              >
                <div
                  class="projects__item__image projects__item__thumb"
                  data-project-uid={p.uid}
                >
                  <img
                    src={p.thumb}
                    alt={p.title}
                    loading={i === 0 ? "eager" : "lazy"}
                    width="520"
                    height="370"
                  />
                </div>
              </a>
            </div>
          ))
        }
      </div>

      <!-- RIGHT — heading + sticky title list + CTA -->
      <div class="projects__titles">
        <div class="projects__titles__wrapper">
          <h2 class="projects__intro" aria-label="Projects"><span
              >Proj</span><span class="projects__intro-dim">ects</span></h2>
          {
            projects.map((p, i) => (
              <h2
                class="projects__title projects__title--desktop"
                data-project-uid={p.uid}
                style={`opacity: ${i === 0 ? 1 : 0.2};`}
              >
                <a href={p.href}>{p.title}</a>
              </h2>
            ))
          }
          <a
            href="/projects"
            class="projects__view-all"
            aria-label="View all projects"
          >
            <span>VIEW ALL PROJECTS</span>
            <svg
              class="projects__view-all__arrow"
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M3.75 14.25L14.25 3.75M14.25 3.75H6.75M14.25 3.75V11.25"
                stroke="white"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ───────────── MOBILE / TABLET (≤1024px) — Swiper carousel ─────────────
       Centered slides; the active slide scales up (echoing the desktop
       expand-on-active effect). The active project's name cross-fades in. -->
  <div class="projects__mobile">
    <h2 class="projects__intro projects__intro--mobile" aria-label="Projects"><span
        >Proj</span><span class="projects__intro-dim">ects</span></h2>

    <div class="swiper projects__swiper">
      <div class="swiper-wrapper">
        {
          projects.map((p) => (
            <div class="swiper-slide projects__slide">
              <a
                class="projects__slide-inner"
                href={p.href}
                aria-label={`See ${p.title}`}
              >
                <img src={p.thumb} alt={p.title} loading="lazy" />
              </a>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Footer — full title list (all visible, active one at full opacity) + CTA -->
    <div class="projects__mobile-footer">
      <div class="projects__mobile-titles" aria-live="polite">
        {
          projects.map((p, i) => (
            <a
              class={`projects__mobile-title-item${i === 0 ? " is-active" : ""}`}
              href={p.href}
              data-index={i}
            >
              {p.title}
            </a>
          ))
        }
      </div>

      <a
        href="/projects"
        class="projects__view-all projects__view-all--mobile"
        aria-label="View all projects"
      >
        <span>VIEW ALL PROJECTS</span>
        <svg
          class="projects__view-all__arrow"
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M3.75 14.25L14.25 3.75M14.25 3.75H6.75M14.25 3.75V11.25"
            stroke="white"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .projects.section {
    position: relative;
  }

  /* ── Desktop / mobile visibility ── */
  .projects__desktop {
    display: none;
  }
  .projects__mobile {
    display: block;
  }

  /* ════════════════ MOBILE / TABLET (≤1024px) ════════════════
     Full-screen section. Header / carousel / titles+CTA are distributed
     uniformly down the viewport via a flex column (Figma "PROJECTS EXTERIOR
     MOBILE"). */
  .projects__mobile {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    align-items: stretch;
    padding: clamp(6.5rem, 15vh, 9rem) 0 clamp(2.5rem, 6vh, 4rem);
    box-sizing: border-box;
  }

  .projects__intro--mobile {
    font-size: clamp(3.25rem, 16vw, 6rem);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    margin: 0;
    padding: 0 2.4rem;
    text-align: left;
  }
  .projects__intro-dim {
    color: rgba(0, 0, 0, 0.19);
  }

  /* Per-character entrance fill (same effect as Cover.astro): every char rests
     faint and GSAP staggers it to its final colour on scroll-in.
     `:global(.char)` is required because SplitText creates the char spans at
     runtime, so they never carry Astro's scoped `data-astro-cid` attribute — a
     scoped `.char` selector would not match them (the "Proj" part would stay
     solid black instead of resting faint). */
  .projects__intro :global(.char) {
    display: inline-block;
    color: rgba(0, 0, 0, 0.08);
  }

  /* Swiper — full-bleed; slides share the BOTTOM baseline (Figma): the active
     slide is full size, neighbours scale down toward that shared bottom edge
     and hug the active slide so they peek on both sides. */
  .projects__swiper {
    width: 100%;
    overflow: hidden;
  }
  .projects__swiper .swiper-wrapper {
    align-items: flex-end;
  }
  .projects__slide {
    width: 72vw;
    box-sizing: border-box;
  }
  .swiper-slide-active {
    z-index: 2; /* active sits above the peeking neighbours */
  }
  .projects__slide-inner {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    /* Neighbour scale kept close to the active slide so the size difference is
       subtle (was 0.64 — too dramatic a jump). */
    transform: scale(0.86);
    transform-origin: bottom center;
    opacity: 1;
    transition:
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.45s ease;
    will-change: transform;
  }
  .projects__slide-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Neighbours scale toward the active slide so they hug it with a slim gap */
  .swiper-slide-prev .projects__slide-inner {
    transform-origin: bottom right;
  }
  .swiper-slide-next .projects__slide-inner {
    transform-origin: bottom left;
  }
  .swiper-slide-active .projects__slide-inner {
    transform: scale(1);
    transform-origin: bottom center;
    opacity: 1;
  }

  /* Footer — full title list (all visible, active at full opacity, the rest
     semi-opaque) + CTA, right-aligned (Figma). */
  .projects__mobile-footer {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1.25rem;
    padding: 0 2.4rem;
  }
  .projects__mobile-titles {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }
  .projects__mobile-title-item {
    font-size: clamp(0.78rem, 3.6vw, 1.2rem);
    font-weight: 500;
    line-height: 1.5;
    white-space: nowrap;
    text-decoration: none;
    color: #000;
    /* Initial paint only — once the carousel inits, GSAP owns this opacity (it
       tweens it on slide change). The CSS `transition` was removed on purpose:
       iOS Safari drops class-toggle opacity transitions fired mid-gesture, and
       leaving it on would also fight GSAP's per-frame writes. */
    opacity: 0.2;
  }
  .projects__mobile-title-item.is-active {
    opacity: 1;
  }

  .projects__view-all--mobile {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.4rem;
    background: black;
    color: white;
    border-radius: 9999px;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .projects__view-all--mobile .projects__view-all__arrow {
    flex-shrink: 0;
    width: 1.3rem;
    height: 1.3rem;
  }

  @media (min-width: 768px) {
    /* Tablet — larger type, slightly narrower slides */
    .projects__slide {
      width: 56vw;
    }
    .projects__intro--mobile,
    .projects__mobile-footer {
      padding-left: 4.2rem;
      padding-right: 4.2rem;
    }
    .projects__mobile-title-item {
      font-size: 1.5rem;
    }
    .projects__view-all--mobile {
      font-size: 1.3rem;
      padding: 0.8rem 1.8rem;
    }
  }

  /* ════════════════ DESKTOP (≥1025px) ════════════════ */
  @media (min-width: 1025px) {
    .projects__desktop {
      display: block;
    }
    .projects__mobile {
      display: none;
    }

    /* Sticky behaviour: section sits above the next section */
    .projects.section {
      padding-bottom: 10rem;
      margin-bottom: 100svh;
      margin-top: -45rem;
      top: 100svh;
    }

    /* Flush-left: no left padding so the image stack hugs the viewport edge
       (Figma "Projects Exterior"); keep right padding for the title column. */
    .projects__container {
      padding: 0 4rem 0 0;
    }

    .projects__grid {
      position: relative;
      display: grid;
      grid-template-columns: repeat(16, 1fr);
      column-gap: 0.625rem;
    }

    /* Image stack — flush against col 1 (viewport's left edge) */
    .projects__wrapper {
      grid-column: 1 / span 7;
      position: relative;
    }

    .projects__item {
      margin-bottom: 0.75rem;
    }
    .projects__item-link {
      display: block;
    }
    .projects__item__image {
      width: 17.55vw;
      overflow: hidden;
      aspect-ratio: 520 / 370;
    }
    .projects__item__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* "Projects" heading — top of the right column, right-aligned, two-tone */
    .projects__intro {
      font-size: clamp(3.5rem, 7vw, 10rem);
      font-weight: 600;
      line-height: 1.04;
      letter-spacing: -0.03em;
      margin: 0 0 clamp(1.8rem, 3.5vw, 4rem);
      text-align: right;
    }

    /* Right sidebar: sticky title list — anchored to the grid's right edge */
    .projects__titles {
      display: flex;
      grid-column: 10 / -1;
      justify-content: flex-end;
      position: relative;
      align-items: flex-end;
      min-height: 100%;
    }
    .projects__titles__wrapper {
      position: sticky;
      bottom: 1.25rem;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      text-align: right;
    }

    .projects__title--desktop {
      display: block;
      font-size: 1.5rem;
      font-weight: 500;
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-align: right;
      transition: opacity 0.3s ease;
      cursor: pointer;
    }
    .projects__title--desktop:hover {
      opacity: 0.5 !important;
    }
    .projects__title--desktop a {
      text-decoration: none;
      color: inherit;
    }

    /* View all projects button */
    .projects__view-all {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1.25rem;
      padding: 0.75rem 1.5rem;
      background: black;
      color: white;
      border-radius: 9999px;
      text-decoration: none;
      font-size: 1.25rem;
      font-weight: 300;
      letter-spacing: 0.05em;
      white-space: nowrap;
      transition: opacity 0.2s ease;
    }
    .projects__view-all:hover {
      opacity: 0.75;
    }
    .projects__view-all__arrow {
      flex-shrink: 0;
      width: 2rem;
      height: 2rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import Swiper from "swiper";
  import "swiper/css";

  gsap.registerPlugin(ScrollTrigger);

  // ≥ this width → desktop scroll-scale layout; below → Swiper carousel.
  const DESKTOP_MIN = 1025;

  class ProjectsSection {
    dom: Element | null;
    projects: HTMLElement[];
    titles: HTMLElement[];
    timeline: gsap.core.Timeline | null;
    swiper: any | null;
    mode: "desktop" | "mobile" | null;
    resizeHandler: (() => void) | null;
    lastViewport: { width: number; height: number } | null;

    constructor() {
      this.dom = document.querySelector(".projects.section");
      this.projects = [];
      this.titles = [];
      this.timeline = null;
      this.swiper = null;
      this.mode = null;
      this.resizeHandler = null;
      this.lastViewport =
        typeof window !== "undefined"
          ? { width: window.innerWidth, height: window.innerHeight }
          : null;
    }

    getMediaRatio(el: Element): number | null {
      const img = el.querySelector("img, video");
      if (!img) return null;
      if (img instanceof HTMLImageElement) {
        const w = img.naturalWidth || img.width;
        const h = img.naturalHeight || img.height;
        if (w && h) return h / w;
      }
      if (img instanceof HTMLVideoElement) {
        const w = img.videoWidth || img.clientWidth;
        const h = img.videoHeight || img.clientHeight;
        if (w && h) return h / w;
      }
      return null;
    }

    getDesktopTitles(): HTMLElement[] {
      const container = this.dom?.querySelector(".projects__titles");
      return container
        ? Array.from(
            container.querySelectorAll<HTMLElement>(
              ".projects__title--desktop",
            ),
          )
        : [];
    }

    destroyTimeline() {
      this.timeline?.scrollTrigger?.kill();
      this.timeline?.kill();
      this.timeline = null;
    }

    cleanupDomState() {
      if (!this.dom) return;
      if (!this.projects.length)
        this.projects = Array.from(
          this.dom.querySelectorAll<HTMLElement>(".projects__item"),
        );
      if (!this.titles.length) this.titles = this.getDesktopTitles();
      this.projects.forEach((item) => {
        const img = item.querySelector<HTMLElement>(".projects__item__image");
        if (img) gsap.set(img, { clearProps: "width,transform,willChange" });
        gsap.set(item, { clearProps: "height,willChange" });
      });
      this.titles.forEach((t) => gsap.set(t, { clearProps: "opacity" }));
      this.titles = [];
    }

    // ── Desktop scroll-scale animation ─────────────────────────────────────
    setupDesktop() {
      if (!this.dom || typeof window === "undefined") return;

      this.projects = Array.from(
        this.dom.querySelectorAll<HTMLElement>(".projects__item"),
      );
      this.titles = this.getDesktopTitles();

      if (!this.projects.length || !this.titles.length) return;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: this.dom,
          start: "top 55%",
          end: "bottom center-=0.5%",
          scrub: true,
          invalidateOnRefresh: true,
        },
      });
      this.timeline = tl;

      // Track first and last DOM item per project index
      const firstByIndex = new Map<number, HTMLElement>();
      const lastByIndex = new Map<number, HTMLElement>();
      this.projects.forEach((item) => {
        const idx = Number(item.dataset.projectIndex ?? 0);
        if (!firstByIndex.has(idx)) firstByIndex.set(idx, item);
        lastByIndex.set(idx, item);
      });

      // Scale constants: collapsed = 17.55vw, expanded = 36vw
      const IMAGE_VW = 17.55;
      const EXPANDED_VW = 36;
      const scaleFactor = EXPANDED_VW / IMAGE_VW;
      const imageWidthStr = `${IMAGE_VW}vw`;

      const collapsedH: number[] = [];
      const expandedH: number[] = [];

      // Set initial state
      this.projects.forEach((item, i) => {
        const img = item.querySelector<HTMLElement>(".projects__item__image");
        if (!img) return;
        const isFirstItem = i === 0;
        const scale = isFirstItem ? scaleFactor : 1;

        gsap.set(img, {
          width: imageWidthStr,
          transformOrigin: "left top",
          scaleX: scale,
          scaleY: scale,
          force3D: true,
        });

        const elW = img.getBoundingClientRect().width || img.offsetWidth;
        const ratio = this.getMediaRatio(img);
        const elH = img.getBoundingClientRect().height;
        const fromRatio = ratio && elW ? elW * ratio : 0;
        const collapsed =
          (elH || fromRatio || item.getBoundingClientRect().height) / scale;
        const expanded = collapsed * scaleFactor;

        collapsedH[i] = collapsed;
        expandedH[i] = expanded;

        gsap.set(item, {
          height: scale === 1 ? collapsed : expanded,
          willChange: "height",
        });
      });

      // Initial title opacities
      const firstIdx = Number(this.projects[0]?.dataset.projectIndex ?? 0);
      this.titles.forEach((t, i) => {
        gsap.set(t, { opacity: i === firstIdx ? 1 : 0.2 });
      });

      // Build the scrubbed scroll timeline
      this.projects.forEach((item, i) => {
        const img = item.querySelector<HTMLElement>(".projects__item__image");
        const projectIdx = Number(item.dataset.projectIndex ?? i);
        const title = this.titles[projectIdx];
        const collapsed = collapsedH[i] ?? 0;
        const expanded = expandedH[i] ?? collapsed * scaleFactor;

        if (!img || !title) return;

        const isFirst = firstByIndex.get(projectIdx) === item;
        const isLast = lastByIndex.get(projectIdx) === item;

        // Expand phase
        tl.to(
          img,
          {
            scaleX: scaleFactor,
            scaleY: scaleFactor,
            force3D: true,
            duration: 0.8,
            ease: "none",
          },
          i,
        );
        if (isFirst)
          tl.to(title, { opacity: 1, duration: 0.4, ease: "none" }, "<");
        tl.to(item, { height: expanded, duration: 0.8, ease: "none" }, "<");

        // Collapse phase
        tl.to(
          img,
          {
            scaleX: 1,
            scaleY: 1,
            force3D: true,
            duration: 1.5,
            ease: "none",
            delay: 0.3,
          },
          ">",
        );
        if (isLast)
          tl.to(title, { opacity: 0.2, duration: 0.4, ease: "none" }, "<");
        tl.to(item, { height: collapsed, duration: 1.5, ease: "none" }, "<");
      });
    }

    setupDesktopRAF() {
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          this.setupDesktop();
          ScrollTrigger.refresh();
        }),
      );
    }

    resetDesktop() {
      this.destroyTimeline();
      this.cleanupDomState();
      this.setupDesktopRAF();
    }

    // ── Mobile / tablet Swiper carousel ────────────────────────────────────
    setupMobile() {
      if (!this.dom) return;
      const el = this.dom.querySelector<HTMLElement>(".projects__swiper");
      if (!el) return;

      const titleItems = Array.from(
        this.dom.querySelectorAll<HTMLElement>(".projects__mobile-title-item"),
      );
      const setActive = (idx: number) => {
        titleItems.forEach((t, i) => {
          const on = i === idx;
          t.classList.toggle("is-active", on);
          // GSAP (not a CSS transition) drives the fade — iOS Safari skips
          // class-toggle opacity transitions fired during the Swiper gesture.
          gsap.to(t, {
            opacity: on ? 1 : 0.2,
            duration: 0.4,
            ease: "power2.out",
            overwrite: "auto",
          });
        });
      };

      this.swiper = new Swiper(el, {
        slidesPerView: "auto",
        centeredSlides: true,
        spaceBetween: 8,
        loop: true,
        grabCursor: true,
        speed: 450,
        on: {
          // realIndex maps loop clones back to the true slide index
          slideChange: (sw: any) => setActive(sw.realIndex),
        },
      });
      setActive(this.swiper.realIndex ?? 0);
    }

    destroySwiper() {
      if (this.swiper) {
        this.swiper.destroy(true, true);
        this.swiper = null;
      }
    }

    // ── Mode switching ─────────────────────────────────────────────────────
    teardownMode() {
      this.destroyTimeline();
      this.cleanupDomState();
      this.destroySwiper();
    }

    applyMode() {
      if (typeof window === "undefined") return;
      const want: "desktop" | "mobile" =
        window.innerWidth >= DESKTOP_MIN ? "desktop" : "mobile";

      if (want === this.mode) {
        if (want === "desktop" && this.shouldResetOnResize()) this.resetDesktop();
        return;
      }

      this.teardownMode();
      this.mode = want;
      if (want === "desktop") this.setupDesktopRAF();
      else this.setupMobile();
    }

    init() {
      if (!this.dom || typeof window === "undefined") return;
      this.applyMode();

      const debounce = (fn: () => void, ms = 200) => {
        let t: ReturnType<typeof setTimeout>;
        return () => {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      };

      this.resizeHandler = debounce(() => this.applyMode(), 200);
      window.addEventListener("resize", this.resizeHandler);
    }

    shouldResetOnResize(): boolean {
      if (typeof window === "undefined") return false;
      if (!this.lastViewport) {
        this.lastViewport = {
          width: window.innerWidth,
          height: window.innerHeight,
        };
        return true;
      }
      const { width: pw, height: ph } = this.lastViewport;
      const nw = window.innerWidth;
      const nh = window.innerHeight;
      const widthChanged = Math.abs(nw - pw) > 10;
      const orientationChanged = nw > nh !== pw > ph;
      const bigHeightChange = Math.abs(nh - ph) > 120;
      this.lastViewport = { width: nw, height: nh };
      return widthChanged || orientationChanged || bigHeightChange;
    }

    destroy() {
      this.teardownMode();
      this.mode = null;
      if (this.resizeHandler && typeof window !== "undefined") {
        window.removeEventListener("resize", this.resizeHandler);
        this.resizeHandler = null;
      }
      this.dom = null;
    }
  }

  let instance: ProjectsSection | null = null;

  function boot() {
    instance?.destroy();
    instance = new ProjectsSection();
    instance.init();
  }

  // Re-init on EVERY navigation. With <ClientRouter/> active, module scripts run
  // only once, so a bare boot() never re-runs when the homepage is reached via a
  // soft (no-reload) View Transition. Hook the lifecycle and tear down before
  // each swap so stale ScrollTriggers / Swipers don't pile up.
  document.addEventListener("astro:page-load", boot);
  document.addEventListener("astro:before-swap", () => {
    instance?.destroy();
    instance = null;
  });
</script>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(SplitText);

  // ── "Projects" heading entrance ──────────────────────────────────────────
  // Per-character colour fill, identical to Cover.astro: the heading rests faint
  // (.char start state) and GSAP staggers every char from grey to solid black.
  // Playback is gated on an IntersectionObserver (NOT ScrollTrigger): the
  // desktop section uses an offset/sticky layout (top: 100svh, margin-top:
  // -45rem) whose box crosses any "top X%" line long before the sticky heading
  // is actually on screen, so a ScrollTrigger fired the fill out of view. The
  // observer watches the heading's real pixels, so it plays exactly when seen.
  // Only the visible heading (desktop OR mobile) is split, so the two copies
  // never fight over the same text.
  let headingSplits: SplitText[] = [];
  let headingObserver: IntersectionObserver | null = null;
  let headingTween: gsap.core.Tween | null = null;

  function initProjectsHeading(): void {
    teardownProjectsHeading();

    const section = document.getElementById("selected-work");
    if (!section || typeof window === "undefined") return;

    const desktop = window.matchMedia("(min-width: 1025px)").matches;
    const heading = section.querySelector<HTMLElement>(
      desktop
        ? ".projects__intro:not(.projects__intro--mobile)"
        : ".projects__intro--mobile",
    );
    if (!heading) return;

    const split = new SplitText(heading, { type: "chars", charsClass: "char" });
    headingSplits.push(split);

    // Paused — plays only once the heading is genuinely in view.
    headingTween = gsap.to(split.chars, {
      color: "#000",
      duration: 0.1,
      ease: "none",
      stagger: { each: 0.06, from: "start" },
      paused: true,
    });

    headingObserver = new IntersectionObserver(
      (entries, obs) => {
        if (entries.some((e) => e.isIntersecting)) {
          headingTween?.play();
          obs.disconnect();
          headingObserver = null;
        }
      },
      { threshold: 0.6 },
    );
    headingObserver.observe(heading);
  }

  function teardownProjectsHeading(): void {
    headingObserver?.disconnect();
    headingObserver = null;
    headingTween?.kill();
    headingTween = null;
    headingSplits.forEach((s) => s.revert());
    headingSplits = [];
  }

  document.addEventListener("astro:page-load", initProjectsHeading);
  document.addEventListener("astro:before-swap", teardownProjectsHeading);
</script>
