---
import logoSrc from "../assets/logo.svg?url";
import RightUpArrow from "../assets/icons/right_up.svg";
---

<!-- Navbar — padding H: 4rem (40px en HD) -->
<nav
    id="main-nav"
    data-theme="light"
    data-frosted="true"
    class="fixed z-100 w-full flex items-center justify-between px-16 py-[2vh] transition-all duration-500"
>
    <a href="/" aria-label="Borsoga Studio">
        <img src={logoSrc} alt="Borsoga Studio" class="nav-logo h-[3.8rem] w-auto transition-[filter] duration-300" />
    </a>

    <ul
        class="absolute left-1/2 -translate-x-1/2 hidden md:flex gap-16 list-none m-0 p-0"
    >
        <li>
            <a
                href="#work"
                class="nav-link no-underline font-bold text-[1.4rem] tracking-[0.02em] transition-[color,opacity] duration-300 hover:opacity-65"
            >
                Work
            </a>
        </li>
        <li>
            <a
                href="#capabilities"
                class="nav-link no-underline font-bold text-[1.4rem] tracking-[0.02em] transition-[color,opacity] duration-300 hover:opacity-65"
            >
                Capabilities
            </a>
        </li>
        <li>
            <a
                href="#contact"
                class="nav-link no-underline font-bold text-[1.4rem] tracking-[0.02em] transition-[color,opacity] duration-300 hover:opacity-65"
            >
                Contact
            </a>
        </li>
    </ul>

    <!-- button: 1.6rem text, padding 1.4/2.8rem -->
    <a
        href="#contact"
        class="inline-flex items-center gap-2 no-underline font-light text-2xl py-3 px-6 rounded-full whitespace-nowrap tracking-wider transition-opacity duration-200 hover:opacity-90 bg-[#0613ff] text-white"
    >
        BEGIN A DIALOGUE
        <RightUpArrow class="h-8" />
    </a>
</nav>

<style>
    /* Frosted state (default) */
    #main-nav[data-frosted="true"] {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 0.5px solid transparent;
    }

    /* Transparent state — sobre categories */
    #main-nav[data-frosted="false"] {
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        border-bottom: none !important;
        background: transparent !important;
    }

    /* Light theme (sobre secciones oscuras) — textos blancos */
    #main-nav[data-theme="light"] .nav-link {
        color: white;
    }
    #main-nav[data-theme="light"] .nav-logo {
        filter: none;
    }
    #main-nav[data-frosted="true"][data-theme="light"] {
        border-bottom-color: rgba(255, 255, 255, 0.2);
    }

    /* Dark theme (sobre secciones claras) — textos negros */
    #main-nav[data-theme="dark"] .nav-link {
        color: black;
    }
    #main-nav[data-theme="dark"] .nav-logo {
        filter: invert(1);
    }
    #main-nav[data-frosted="true"][data-theme="dark"] {
        border-bottom-color: rgba(0, 0, 0, 0.12);
    }

    /* BEGIN A DIALOGUE button — siempre visible */
    #main-nav[data-theme="dark"] .nav-cta {
        background: #0613ff;
        color: white;
    }
</style>

<script>
    function initNavTheme() {
        const nav = document.getElementById("main-nav");
        if (!nav) return;

        const darkSections        = document.querySelectorAll<HTMLElement>("[data-navbar-dark]");
        const transparentSections = document.querySelectorAll<HTMLElement>("[data-navbar-transparent]");

        function updateTheme() {
            const navH = nav!.offsetHeight;

            const anyDark = Array.from(darkSections).some((el) => {
                const rect = el.getBoundingClientRect();
                return rect.top <= navH && rect.bottom > navH;
            });

            const anyTransparent = Array.from(transparentSections).some((el) => {
                const rect = el.getBoundingClientRect();
                return rect.top <= navH && rect.bottom > navH;
            });

            nav!.dataset.theme   = anyDark ? "light" : "dark";
            nav!.dataset.frosted = anyTransparent ? "false" : "true";
        }

        if (!darkSections.length) nav.dataset.theme = "dark";

        window.addEventListener("scroll", updateTheme, { passive: true });
        updateTheme();
    }

    // Astro view transitions
    document.addEventListener("astro:page-load", initNavTheme);
    if (document.readyState !== "loading") initNavTheme();
    else document.addEventListener("DOMContentLoaded", initNavTheme);
</script>
