---
import logoSrc from "../assets/logo.svg?url";
import logoStackedSrc from "../assets/logo-stacked.svg?url";
import RightUpArrow from "../assets/icons/right_up.svg";
---

<!-- Navbar — padding H: 4rem (40px en HD) -->
<nav
    id="main-nav"
    data-theme="light"
    data-frosted="true"
    class="fixed z-100 w-full flex items-center justify-between px-[2.4rem] md:px-[4.2rem] lg:px-16 py-[2vh] transition-all duration-500"
>
    <a href="/" aria-label="Borsoga Studio">
        <!-- stacked mark on mobile/tablet, horizontal wordmark on desktop (from Figma) -->
        <img
            src={logoStackedSrc}
            alt="Borsoga Studio"
            class="nav-logo block lg:hidden h-[3.8rem] w-auto transition-[filter] duration-300"
        />
        <img
            src={logoSrc}
            alt="Borsoga Studio"
            class="nav-logo hidden lg:block h-[3.8rem] w-auto transition-[filter] duration-300"
        />
    </a>

    <ul
        class="absolute left-1/2 -translate-x-1/2 hidden lg:flex gap-16 list-none m-0 p-0"
    >
        <li>
            <a
                href="#work"
                class="nav-link no-underline font-bold text-[1.4rem] tracking-[0.02em] transition-[color,opacity] duration-300 hover:opacity-65"
            >
                Work
            </a>
        </li>
        <li>
            <a
                href="#capabilities"
                class="nav-link no-underline font-bold text-[1.4rem] tracking-[0.02em] transition-[color,opacity] duration-300 hover:opacity-65"
            >
                Capabilities
            </a>
        </li>
        <li>
            <a
                href="#contact"
                class="nav-link no-underline font-bold text-[1.4rem] tracking-[0.02em] transition-[color,opacity] duration-300 hover:opacity-65"
            >
                Contact
            </a>
        </li>
    </ul>

</nav>

<!--
  CTA en su propia capa de apilamiento, por ENCIMA del SVG decorativo del
  cover (z-110), que a su vez va por encima del banner del navbar (z-100).
  La capa es transparente y pointer-events:none salvo el botón, para no
  bloquear clics sobre el logo / links del nav que quedan debajo.
-->
<div
    class="nav-cta-layer fixed top-0 left-0 z-120 w-full px-[2.4rem] md:px-[4.2rem] lg:px-16 py-[2vh] flex justify-end pointer-events-none"
>
    <div class="min-h-[3.8rem] flex items-center">
        <!-- BEGIN A DIALOGUE — smaller on mobile/tablet, full on desktop -->
        <a
            href="#contact"
            class="nav-cta pointer-events-auto inline-flex items-center gap-1 md:gap-2 no-underline font-light text-[1rem] md:text-[1.3rem] lg:text-[1.25rem] py-[0.6rem] px-[1.4rem] md:py-[0.8rem] md:px-[1.8rem] lg:py-3 lg:px-6 rounded-full whitespace-nowrap tracking-wider hover:opacity-90"
        >
            BEGIN A DIALOGUE
            <RightUpArrow class="h-[1.1rem] md:h-[1.3rem] lg:h-[1.6rem]" />
        </a>
    </div>
</div>

<style>
    /* Frosted state (default) */
    #main-nav[data-frosted="true"] {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1.5px solid transparent;
    }

    /* Transparent state — sobre categories */
    #main-nav[data-frosted="false"] {
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        border-bottom: none !important;
        background: transparent !important;
    }

    /* Light theme (sobre secciones oscuras) — textos blancos */
    #main-nav[data-theme="light"] .nav-link {
        color: white;
    }
    #main-nav[data-theme="light"] .nav-logo {
        filter: none;
    }
    #main-nav[data-frosted="true"][data-theme="light"] {
        border-bottom-color: rgba(255, 255, 255, 0.55);
    }

    /* Dark theme (sobre secciones claras) — textos negros */
    #main-nav[data-theme="dark"] .nav-link {
        color: black;
    }
    #main-nav[data-theme="dark"] .nav-logo {
        filter: invert(1);
    }
    #main-nav[data-frosted="true"][data-theme="dark"] {
        border-bottom-color: rgba(0, 0, 0, 0.45);
    }

    /* BEGIN A DIALOGUE button (vive en .nav-cta-layer, hermana de #main-nav).
       Contrasta con la sección: tema oscuro (sobre fondo claro) → fondo negro /
       texto blanco; tema claro (sobre fondo oscuro) → fondo blanco / texto negro.
       La flecha usa currentColor, así que sigue el color del texto. */
    .nav-cta {
        background: #fff;
        color: #000;
        transition:
            background-color 0.3s ease,
            color 0.3s ease,
            opacity 0.2s ease;
    }
    #main-nav[data-theme="dark"] ~ .nav-cta-layer .nav-cta {
        background: #000;
        color: #fff;
    }
    #main-nav[data-theme="light"] ~ .nav-cta-layer .nav-cta {
        background: #fff;
        color: #000;
    }

    /* Mobile & tablet — siempre frosted, nunca transparente.
       Se necesita background explícito porque blur sobre fondo sólido
       no produce efecto visual sin color de fondo. */
    @media (max-width: 1024px) {
        #main-nav[data-frosted="false"]:not([data-noblur="true"]) {
            backdrop-filter: blur(20px) !important;
            -webkit-backdrop-filter: blur(20px) !important;
        }
    }
</style>

<script>
    function initNavTheme() {
        const nav = document.getElementById("main-nav");
        if (!nav) return;

        const darkSections        = document.querySelectorAll<HTMLElement>("[data-navbar-dark]");
        const transparentSections = document.querySelectorAll<HTMLElement>("[data-navbar-transparent]");
        const noBlurSections      = document.querySelectorAll<HTMLElement>("[data-navbar-noblur]");

        function isUnderNav(el: HTMLElement, navH: number) {
            const rect = el.getBoundingClientRect();
            return rect.top <= navH && rect.bottom > navH;
        }

        function updateTheme() {
            const navH = nav!.offsetHeight;

            const anyDark        = Array.from(darkSections).some((el) => isUnderNav(el, navH));
            const anyTransparent = Array.from(transparentSections).some((el) => isUnderNav(el, navH));
            const anyNoBlur      = Array.from(noBlurSections).some((el) => isUnderNav(el, navH));

            nav!.dataset.theme   = anyDark ? "light" : "dark";
            nav!.dataset.frosted = anyTransparent ? "false" : "true";
            // Suppress the mobile/tablet forced-blur over sections that opt out
            // (e.g. the cover, so its animated spiral reads crisply behind the nav).
            nav!.dataset.noblur  = anyNoBlur ? "true" : "false";
        }

        if (!darkSections.length) nav.dataset.theme = "dark";

        window.addEventListener("scroll", updateTheme, { passive: true });
        updateTheme();
    }

    // Astro view transitions
    document.addEventListener("astro:page-load", initNavTheme);
    if (document.readyState !== "loading") initNavTheme();
    else document.addEventListener("DOMContentLoaded", initNavTheme);
</script>
