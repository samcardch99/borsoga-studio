---
const categories = [
  {
    id: "arch-viz",
    title: "Architectural Visualization",
    description:
      "We translate ideas, concepts, sketches, and architectural plans into accurate, atmospheric imagery and animations. We focus on natural light, true human scale, and the honest representation of materials to evoke the exact emotion of the space.",
    tags: ["V-RAY", "RHINO"],
    bgColor: "#0a0a0a",
    textColor: "#fff",
    tagBorder: "rgba(255,255,255,0.5)",
    ctaBg: "#fff",
    ctaColor: "#000",
    bgStyle: "background-color:#0a0a0a;",
    noGradient: true,
    customGradient: undefined as string | undefined,
    contentBlur: undefined as string | undefined,
    bgImg: undefined as string | undefined,
    bgImgStyle: undefined as string | undefined,
  },
  {
    id: "immersive",
    title: "Interactive &\nImmersive Spaces",
    description:
      "Buyers don't just want to see a space; they want to experience it. We develop real-time immersive environments and interactive 3D walkthroughs, allowing users to navigate and feel the atmosphere of a project before it physically exists.",
    tags: ["FLOOR PLAN UI", "BESPOKE SITES", "PERFORMANCE & SEO"],
    bgColor: "#f6f5f1",
    textColor: "#1a1a1a",
    tagBorder: "rgba(0,0,0,0.5)",
    ctaBg: "#000",
    ctaColor: "#fff",
    bgStyle: "background-color:#f6f5f1;",
    noGradient: true,
    customGradient: undefined as string | undefined,
    contentBlur: undefined as string | undefined,
    bgImg: "/categories/cat2-bg.jpg",
    bgImgStyle:
      "position:absolute;left:21.71%;top:-63.58%;width:78.29%;height:177.69%;object-fit:cover;pointer-events:none;",
  },
  {
    id: "web",
    title: "Custom Web Platforms",
    description:
      "A memorable project deserves a unique space to live online. We design and build fast, intuitive websites where clients can easily explore floor plans, interact with the space, and understand the property from anywhere.",
    tags: ["FLOOR PLAN UI", "BESPOKE SITES", "PERFORMANCE & SEO"],
    bgColor: "#e8e4de",
    textColor: "#fff",
    tagBorder: "rgba(255,255,255,0.6)",
    ctaBg: "#fff",
    ctaColor: "#000",
    bgStyle: "background-color:#e8e4de;",
    noGradient: true,
    customGradient: undefined as string | undefined,
    contentBlur: undefined as string | undefined,
    bgImg: undefined as string | undefined,
    bgImgStyle: undefined as string | undefined,
  },
  {
    id: "brand",
    title: "Brand Identity",
    description:
      "We build identities for the entire built environment. Whether you are launching an architectural practice, a new development, or a product line, we design the naming, visual systems, and presentation decks that give your vision its own distinct voice.",
    tags: ["NAMING", "VISUAL SYSTEMS", "PRESENTATION DECKS", "GUIDELINES"],
    bgColor: "#1a1a1a",
    textColor: "#fff",
    tagBorder: "rgba(255,255,255,0.6)",
    ctaBg: "#fff",
    ctaColor: "#000",
    bgStyle: "background-color:#1a1a1a;",
    noGradient: true,
    customGradient: undefined as string | undefined,
    contentBlur: undefined as string | undefined,
    bgImg: undefined as string | undefined,
    bgImgStyle: undefined as string | undefined,
  },
];
---

<section class="cat" id="categories" data-navbar-transparent>
  <div class="cat__sticky">
    <!-- Flanking columns — absolute, centered vertically inside the pinned viewport -->
    <div class="cat__flank cat__flank--left" id="cat-flank-left">
      <p class="cat__flank-label">What we do</p>
      <p class="cat__flank-heading">
        Everything aligned to produce a clear vision.
      </p>
    </div>
    <div class="cat__flank cat__flank--right" id="cat-flank-right">
      <p class="cat__flank-label">Services</p>
      <ul class="cat__flank-list">
        <li>Arch. Visualization</li>
        <li>Immersive Spaces</li>
        <li>Web Platforms</li>
        <li>Brand Identity</li>
      </ul>
    </div>

    <!-- Card shell -->
    <div class="cat__card-wrap" id="cat-card-wrap">
      <div class="cat__border" id="cat-border"></div>

      {
        categories.map((cat, i) => (
          <div
            class={`cat__slide${i === 0 ? " is-active cat__slide--first" : ""}`}
            data-cat-index={i}
            style={`--cat-bg:${cat.bgColor};--cat-text:${cat.textColor};--cat-tag-border:${cat.tagBorder};--cat-cta-bg:${cat.ctaBg};--cat-cta-color:${cat.ctaColor};`}
          >
            <div class="cat__bg" style={cat.bgStyle}>
              {i === 0 && (
                <>
                  {[1,2,3,4,5].map((n) => (
                    <img
                      src={`/categories/animated-architecture-opt/${n}.jpg`}
                      alt=""
                      class="cat__light-frame"
                      data-light-frame={n}
                      style={n === 1 ? "opacity:1" : "opacity:0"}
                    />
                  ))}
                </>
              )}
              {cat.bgImg && (
                <img
                  src={cat.bgImg}
                  alt=""
                  id={i === 1 ? "cat-parallax-bg" : undefined}
                  style={cat.bgImgStyle}
                />
              )}
              {i === 1 && (
                <img
                  src="/categories/recorte.png"
                  alt=""
                  class="cat__parallax-fg"
                  style={cat.bgImgStyle}
                />
              )}
              {i === 2 && (
                <>
                  <img
                    src="/categories/fondo.png"
                    alt=""
                    id="cat-s3-bg"
                    class="cat__s3-layer cat__s3-bg"
                  />
                  <img
                    src="/categories/laptop1.png"
                    alt=""
                    id="cat-s3-laptop1"
                    class="cat__s3-layer cat__s3-fg"
                  />
                  <img
                    src="/categories/laptop2.png"
                    alt=""
                    id="cat-s3-laptop2"
                    class="cat__s3-layer cat__s3-fg"
                  />
                  <img
                    src="/categories/piedra.png"
                    alt=""
                    id="cat-s3-piedra"
                    class="cat__s3-layer cat__s3-fg"
                  />
                </>
              )}
              {i === 3 && (
                <>
                  <img
                    src="/categories/branding1.png"
                    alt=""
                    id="cat-s4-bg"
                    class="cat__s4-layer cat__s4-bg"
                  />
                  <img
                    src="/categories/branding2.png"
                    alt=""
                    id="cat-s4-mid"
                    class="cat__s4-layer cat__s4-mid"
                  />
                  <img
                    src="/categories/branding3.png"
                    alt=""
                    id="cat-s4-top"
                    class="cat__s4-layer cat__s4-top"
                  />
                </>
              )}
            </div>

            <div class="cat__content">
              <h3 class="cat__title">
                <span class="cat__title-inner">{cat.title}</span>
              </h3>
              <p class="cat__desc">{cat.description}</p>
              <ul class="cat__tags">
                {cat.tags.map((tag) => (
                  <li class="cat__tag">{tag}</li>
                ))}
              </ul>
            </div>

            <a href="/works/" class="cat__cta">
              VIEW OUR WORK
              <svg
                width="13"
                height="13"
                viewBox="0 0 18 18"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3.75 14.25L14.25 3.75M14.25 3.75H6.75M14.25 3.75V11.25"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </div>
        ))
      }

      <div class="cat__dots">
        {
          categories.map((_, i) => (
            <button
              class={`cat__dot${i === 0 ? " is-active" : ""}`}
              data-cat-dot={i}
              aria-label={`Category ${i + 1}`}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .cat {
    position: relative;
    background: #000;
  }

  /* ── Sticky viewport — pinned by GSAP, not CSS ── */
  .cat__sticky {
    position: relative;
    height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  /* ── Flanking columns — absolute inside pinned sticky ── */
  .cat__flank {
    position: absolute;
    top: 50%;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    z-index: 20;
    pointer-events: none;
    transition:
      opacity 0.35s ease,
      visibility 0.35s ease;
  }
  .cat__flank--left {
    left: clamp(2rem, 5vw, 7rem);
    width: calc(28vw - 1rem);
    text-align: left;
  }
  .cat__flank--right {
    right: clamp(2rem, 5vw, 7rem);
    width: calc(28vw - 1rem);
    text-align: right;
  }

  .cat__flank-label {
    margin: 0;
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.6rem, 0.7vw, 0.8rem);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }
  .cat__flank-heading {
    margin: 0;
    font-family: "Poppins", sans-serif;
    font-size: clamp(1.6rem, 2.2vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: #fff;
    /* stretch text to fill the full flank width */
    width: 100%;
  }
  .cat__flank-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cat__flank-list li {
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.9rem, 1.1vw, 1.4rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.04em;
  }

  /* ── Card shell ── */
  .cat__card-wrap {
    position: relative;
    width: 100%;
    height: 100svh;
    overflow: hidden;
    transform: scale(0.4);
    transform-origin: center center;
    opacity: 0.8;
    z-index: 5;
  }

  /* ── Border top ── */
  .cat__border {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1.5px;
    background: rgba(255, 255, 255, 0.3);
    transform: scaleX(0);
    transform-origin: left center;
    z-index: 10;
  }

  /* ── Slides ── */
  .cat__slide {
    position: absolute;
    inset: 0;
    background-color: var(--cat-bg);
    color: var(--cat-text);
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .cat__slide.is-active {
    opacity: 1;
  }

  .cat__slide--first .cat__content {
    z-index: 2;
  }

  /* ── Background image ── */
  .cat__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  /* ── Parallax slide 2: fg static, bg moves ── */
  .cat__parallax-fg {
    scale: 1.08;
    transform-origin: center center;
    z-index: 2;
    pointer-events: none;
  }
  #cat-parallax-bg {
    will-change: transform;
    scale: 1.2;
    transform-origin: center center;
  }

  /* ── Lighting frames slide 1 ── */
  .cat__light-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    pointer-events: none;
    will-change: opacity;
  }

  /* ── Parallax slide 3: fondo + laptops + piedra ── */
  .cat__s3-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    pointer-events: none;
    will-change: transform;
  }
  .cat__s3-bg {
    scale: 1.12;
    z-index: 0;
  }
  .cat__s3-fg {
    scale: 1.05;
    z-index: 1;
    object-position: 15% center;
  }
  #cat-s3-piedra  { z-index: 2; }
  #cat-s3-laptop1 { z-index: 3; }
  #cat-s3-laptop2 { z-index: 4; }
  [data-cat-index="2"] .cat__content,
  [data-cat-index="2"] .cat__cta { z-index: 10; }

  /* ── Parallax slide 4: branding layers ── */
  .cat__s4-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    pointer-events: none;
    will-change: transform;
  }
  .cat__s4-bg  { scale: 1.12; z-index: 0; }
  .cat__s4-mid { scale: 1.05; z-index: 1; }
  .cat__s4-top { scale: 1.05; z-index: 2; }
  [data-cat-index="3"] .cat__content,
  [data-cat-index="3"] .cat__cta { z-index: 10; }

  /* ── Content panel ── */
  .cat__content {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: clamp(280px, 44%, 620px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 clamp(1.5rem, 3vw, 4rem);
    padding-left: clamp(2rem, 3vw, 4rem);
    background: transparent;
  }

  /* Figma: título 48px en frame 2526px → ~1.9vw, desc 24px → ~0.95vw, tags 28px → ~1.1vw */
  .cat__title {
    margin: 0 0 clamp(0.8rem, 1.4vw, 1.8rem);
    font-family: "Poppins", sans-serif;
    font-size: clamp(1.6rem, 1.9vw, 2.8rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    white-space: pre-line;
    overflow: hidden;
  }
  .cat__title-inner {
    display: block;
  }
  .cat__desc {
    margin: 0 0 clamp(1rem, 1.8vw, 2.4rem);
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.75rem, 0.95vw, 1.2rem);
    font-weight: 300;
    line-height: 1.65;
    max-width: 38ch;
  }
  .cat__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cat__tag {
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.6rem, 0.75vw, 0.95rem);
    font-weight: 300;
    letter-spacing: 0.06em;
    padding: 0.45em 1.2em;
    border-radius: 9999px;
    border: 1px solid var(--cat-tag-border);
    white-space: nowrap;
  }
  /* CTA — absolute, vertically centered, right side */
  .cat__cta {
    position: absolute;
    top: 50%;
    right: clamp(2rem, 3.5vw, 4.5rem);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.75rem, 1vw, 1.2rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--cat-cta-color);
    background: var(--cat-cta-bg);
    text-decoration: none;
    padding: 0.8em 1.8em;
    border-radius: 9999px;
    transition: opacity 0.2s;
    z-index: 3;
  }
  .cat__cta:hover {
    opacity: 0.75;
  }

  /* ── Content reveal states — all slides start hidden ── */
  .cat__title-inner,
  .cat__desc,
  .cat__tags {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.75s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cat__cta {
    opacity: 0;
    transform: translateY(calc(-50% + 18px));
    transition:
      opacity 0.75s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Reveal class — JS adds .content-in on the slide when it becomes active */
  .cat__slide.content-in .cat__title-inner {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0s;
  }
  .cat__slide.content-in .cat__desc {
    opacity: 0.75;
    transform: translateY(0);
    transition-delay: 0.12s;
  }
  .cat__slide.content-in .cat__tags {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.22s;
  }
  .cat__slide.content-in .cat__cta {
    opacity: 1;
    transform: translateY(-50%);
    transition-delay: 0.34s;
  }

  /* ── Nav dots ── */
  .cat__dots {
    position: absolute;
    bottom: clamp(0.8rem, 1.5vw, 1.5rem);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.45rem;
    z-index: 10;
  }
  .cat__dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    border: none;
    background: rgba(200, 200, 200, 0.35);
    cursor: pointer;
    padding: 0;
    transition:
      background 0.3s,
      transform 0.3s;
  }
  .cat__dot.is-active {
    background: rgba(200, 200, 200, 0.8);
    transform: scale(1.5);
  }

  @media (max-width: 640px) {
    .cat__flank {
      display: none;
    }
    .cat__content {
      width: 100%;
      padding: 1.5rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

  const cardWrap = document.getElementById("cat-card-wrap") as HTMLElement;
  const border = document.getElementById("cat-border") as HTMLElement;
  const flankL = document.getElementById("cat-flank-left") as HTMLElement;
  const flankR = document.getElementById("cat-flank-right") as HTMLElement;
  const slides = Array.from(
    document.querySelectorAll<HTMLElement>(".cat__slide"),
  );
  const dots = Array.from(document.querySelectorAll<HTMLElement>(".cat__dot"));

  const N = slides.length;
  const VH = () => window.innerHeight;
  const ENTER_SCROLL = () => VH() * 0.8;
  const SLIDE_SCROLL = () => VH() * 0.75;
  const TOTAL = () => ENTER_SCROLL() + N * SLIDE_SCROLL();

  const SCALE_START = 0.4;
  const SCALE_RANGE = 0.6;
  const PARALLAX_X = 40;
  const FADE_START = 0.72;

  // true = slide has dark bg → navbar needs light (white) text
  const SLIDE_IS_DARK = [false, false, false, true];

  const catSection = document.getElementById("categories") as HTMLElement;

  function updateNavbarTheme(idx: number) {
    if (SLIDE_IS_DARK[idx]) {
      catSection.setAttribute("data-navbar-dark", "");
    } else {
      catSection.removeAttribute("data-navbar-dark");
    }
  }

  // Centre the flanks vertically via GSAP (keeps transform clean)
  gsap.set([flankL, flankR], { yPercent: -50 });

  let currentSlide = 0;
  let enterComplete = false;

  function revealSlide(idx: number) {
    requestAnimationFrame(() =>
      requestAnimationFrame(() => {
        slides[idx].classList.add("content-in");
      }),
    );
  }

  function hideSlide(idx: number) {
    slides[idx].classList.remove("content-in");
  }

  function setSlide(idx: number) {
    if (idx === currentSlide) return;
    const prev = currentSlide;
    slides[currentSlide].classList.remove("is-active");
    dots[currentSlide].classList.remove("is-active");
    hideSlide(currentSlide);
    currentSlide = idx;
    slides[currentSlide].classList.add("is-active");
    dots[currentSlide].classList.add("is-active");
    revealSlide(currentSlide);
    updateNavbarTheme(currentSlide);
    // Notify parallax system of slide change
    if ((window as any).__catSetSlide) (window as any).__catSetSlide(idx);
  }

  function onProgress(p: number) {
    const enterEnd = ENTER_SCROLL() / TOTAL();
    const enterP = Math.min(1, p / enterEnd);

    gsap.set(cardWrap, {
      scale: SCALE_START + SCALE_RANGE * enterP,
      opacity: 0.8 + 0.2 * enterP,
      transformOrigin: "center center",
    });
    gsap.set(border, { scaleX: enterP });

    // Feed enterP into the lighting system (slide 1, scroll phase)
    (window as any).__catLighting?.setLightFromScroll(enterP);

    // Parallax: flanks drift outward as card grows
    const drift = PARALLAX_X * enterP;
    // Opacity: visible until FADE_START, then fade to 0 at enterP=1
    const opacity =
      enterP < FADE_START
        ? 1
        : Math.max(0, 1 - (enterP - FADE_START) / (1 - FADE_START));
    const visible = opacity > 0;

    gsap.set(flankL, {
      x: -drift,
      opacity,
      visibility: visible ? "visible" : "hidden",
    });
    gsap.set(flankR, {
      x: drift,
      opacity,
      visibility: visible ? "visible" : "hidden",
    });

    if (enterP >= 1 && !enterComplete) {
      enterComplete = true;
      revealSlide(0);
      updateNavbarTheme(currentSlide);
      catSection.removeAttribute("data-navbar-transparent");
(window as any).__catLighting?.lightHandoffToMouse();
      if (currentSlide === 1 && (window as any).__catSetSlide)
        (window as any).__catSetSlide(1);
    } else if (enterP < 1 && enterComplete) {
      enterComplete = false;
      (window as any).__catLighting?.lightHandoffToScroll();
      hideSlide(0);
      catSection.removeAttribute("data-navbar-dark");
      catSection.setAttribute("data-navbar-transparent", "");
    }

    if (enterP >= 1) {
      const slideP = (p - enterEnd) / (1 - enterEnd);
      setSlide(Math.min(N - 1, Math.floor(slideP * N)));
    } else {
      setSlide(0);
    }
  }

  function createTrigger() {
    ScrollTrigger.create({
      trigger: ".cat__sticky",
      start: "top top",
      end: () => `+=${TOTAL()}`,
      pin: true,
      scrub: true,
      onUpdate: (self) => onProgress(self.progress),
    });
  }

  if ((window as any).lenisReady) {
    createTrigger();
  } else {
    window.addEventListener("lenis:ready", createTrigger, { once: true });
  }

  dots.forEach((dot, i) =>
    dot.addEventListener("click", () => {
      if (enterComplete) setSlide(i);
    }),
  );

  // ── Slide 1: cinematic lighting ──
  // Phase A (scroll): enterP 0→1 drives lighting dark→bright, scrubable in both directions
  // Phase B (mouse):  once enterComplete, mouse X controls lighting freely
  {
    const FRAME_COUNT = 5;
    const lightFrames = Array.from(
      document.querySelectorAll<HTMLImageElement>(".cat__light-frame")
    );
    lightFrames.forEach(f => { if (!f.complete) f.decode?.(); });

    let lightCurrent = 0;  // lerped display value (0=dark, 1=bright)
    let lightTarget = 0;   // what lightCurrent chases
    let mouseMode = false; // false = scroll drives, true = mouse drives

    function applyLighting(v: number) {
      const fi = v * (FRAME_COUNT - 1);
      lightFrames.forEach((img, i) => {
        const dist = Math.abs(i - fi);
        img.style.opacity = String(Math.max(0, 1 - dist));
      });
    }

    // Called from onProgress every scroll tick
    function setLightFromScroll(enterP: number) {
      if (mouseMode) return;
      lightTarget = enterP;
      lightCurrent = enterP; // scroll is already scrubbed — apply directly, no lerp
      applyLighting(lightCurrent);
    }

    // Called when enterComplete flips true: hand off control to mouse
    function lightHandoffToMouse() {
      mouseMode = true;
      lightTarget = 1; // stays at fully lit until mouse moves
    }

    // Called when enterComplete flips false (scrolling back up): back to scroll control
    function lightHandoffToScroll() {
      mouseMode = false;
    }

    function lightTick() {
      if (mouseMode && currentSlide === 0 && enterComplete) {
        lightCurrent = lerp(lightCurrent, lightTarget, 0.05);
        applyLighting(lightCurrent);
      }
      requestAnimationFrame(lightTick);
    }

    window.addEventListener("mousemove", (e) => {
      if (!mouseMode || currentSlide !== 0 || !enterComplete) return;
      lightTarget = e.clientX / window.innerWidth;
    }, { passive: true });

    (window as any).__catLighting = { setLightFromScroll, lightHandoffToMouse, lightHandoffToScroll };

    lightTick();
  }

  // ── Mouse parallax: slide 2 (bg + recorte) and slide 3 (fondo + laptops + piedra) ──

  // Slide 2 elements
  const s2bg = document.getElementById("cat-parallax-bg") as HTMLElement | null;
  const s2fg = document.querySelector<HTMLElement>(".cat__parallax-fg");
  // Slide 3 elements
  const s3bg     = document.getElementById("cat-s3-bg")     as HTMLElement | null;
  const s3laptop1 = document.getElementById("cat-s3-laptop1") as HTMLElement | null;
  const s3laptop2 = document.getElementById("cat-s3-laptop2") as HTMLElement | null;
  const s3piedra  = document.getElementById("cat-s3-piedra")  as HTMLElement | null;
  // Slide 4 elements
  const s4bg  = document.getElementById("cat-s4-bg")  as HTMLElement | null;
  const s4mid = document.getElementById("cat-s4-mid") as HTMLElement | null;
  const s4top = document.getElementById("cat-s4-top") as HTMLElement | null;

  const BG_STRENGTH  = 16;
  const FG_STRENGTH  = 7;
  const FG2_STRENGTH = 10; // mid-layer for laptop2 / piedra

  // Shared lerped positions — index 0=bg, 1=fg1, 2=fg2, 3=fg3
  type Layer = { tx: number; ty: number; x: number; y: number; el: HTMLElement | null; strength: number };
  const s2layers: Layer[] = [
    { tx: 0, ty: 0, x: 0, y: 0, el: s2bg,  strength: BG_STRENGTH },
    { tx: 0, ty: 0, x: 0, y: 0, el: s2fg,  strength: FG_STRENGTH },
  ];
  const s3layers: Layer[] = [
    { tx: 0, ty: 0, x: 0, y: 0, el: s3bg,     strength: BG_STRENGTH  },
    { tx: 0, ty: 0, x: 0, y: 0, el: s3laptop1, strength: FG_STRENGTH  },
    { tx: 0, ty: 0, x: 0, y: 0, el: s3laptop2, strength: FG2_STRENGTH },
    { tx: 0, ty: 0, x: 0, y: 0, el: s3piedra,  strength: FG2_STRENGTH },
  ];
  const s4layers: Layer[] = [
    { tx: 0, ty: 0, x: 0, y: 0, el: s4bg,  strength: BG_STRENGTH  },
    { tx: 0, ty: 0, x: 0, y: 0, el: s4mid, strength: FG_STRENGTH  },
    { tx: 0, ty: 0, x: 0, y: 0, el: s4top, strength: FG2_STRENGTH },
  ];

  let mouseActive = false;
  let demoTween: gsap.core.Tween | null = null;
  const demoProxy = { t: 0 };
  const ARC_NX = 1.0;

  function setLayerTargets(layers: Layer[], nx: number, ny: number) {
    for (const l of layers) {
      l.tx = -nx * l.strength;
      l.ty =  ny * l.strength;
    }
  }

  function resetLayerTargets(layers: Layer[]) {
    for (const l of layers) { l.tx = 0; l.ty = 0; }
  }

  function applyDemo() {
    const active = currentSlide === 1 ? s2layers : currentSlide === 2 ? s3layers : s4layers;
    for (const l of active) {
      l.tx = -ARC_NX * demoProxy.t * l.strength;
      l.ty = 0;
    }
  }

  function playDemoParallax() {
    if (demoTween) demoTween.kill();
    mouseActive = false;
    demoProxy.t = 0;
    demoTween = gsap.to(demoProxy, {
      t: 1,
      duration: 2.0,
      ease: "power2.out",
      onUpdate: applyDemo,
      onComplete() { demoTween = null; },
    });
  }

  function stopDemo() {
    if (demoTween) { demoTween.kill(); demoTween = null; }
    mouseActive = true;
  }

  function tick() {
    const allLayers = [...s2layers, ...s3layers, ...s4layers];
    for (const l of allLayers) {
      if (!l.el) continue;
      l.x = lerp(l.x, l.tx, 0.06);
      l.y = lerp(l.y, l.ty, 0.06);
      l.el.style.translate = `${l.x}px ${l.y}px`;
    }
    requestAnimationFrame(tick);
  }

  window.addEventListener("mousemove", (e) => {
    const isParallaxSlide = (currentSlide === 1 || currentSlide === 2 || currentSlide === 3) && enterComplete;
    if (!isParallaxSlide) {
      resetLayerTargets(s2layers);
      resetLayerTargets(s3layers);
      resetLayerTargets(s4layers);
      mouseActive = false;
      return;
    }
    if (!mouseActive) stopDemo();
    const nx = (e.clientX / window.innerWidth  - 0.5) * 2;
    const ny = (e.clientY / window.innerHeight - 0.5) * 2;
    if (currentSlide === 1) setLayerTargets(s2layers, nx, ny);
    if (currentSlide === 2) setLayerTargets(s3layers, nx, ny);
    if (currentSlide === 3) setLayerTargets(s4layers, nx, ny);
  }, { passive: true });

  window.addEventListener("mouseleave", () => {
    resetLayerTargets(s2layers);
    resetLayerTargets(s3layers);
    resetLayerTargets(s4layers);
  }, { passive: true });

  (window as any).__catSetSlide = (idx: number) => {
    if (idx === 1 || idx === 2 || idx === 3) {
      playDemoParallax();
    } else {
      stopDemo();
      resetLayerTargets(s2layers);
      resetLayerTargets(s3layers);
      resetLayerTargets(s4layers);
      mouseActive = false;
    }
  };

  tick();
</script>
