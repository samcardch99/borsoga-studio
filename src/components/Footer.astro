---
import Form from "./helpers/Form.jsx";
import wordmarkSrc from "../assets/footer-wordmark.svg?url";
import arrowSrc from "../assets/icons/right_up.svg?url";
---

<!--
  Figma frame: 2526px wide.  Font scale: figmaPx / 2526 * 100vw
  ─────────────────────────────────────────────────────────────
  Headline:       200px → 7.92vw  clamp(2.4rem,  7.92vw, 13rem)
  Social links:    48px → 1.90vw  clamp(1.05rem, 1.90vw, 3.25rem)
  Channel text:    36px → 1.43vw  clamp(0.78rem, 1.43vw, 2.1rem)
  Elsewhere/bottom:32px → 1.27vw  clamp(0.68rem, 1.27vw, 1.85rem)
  Send btn:        28px → 1.11vw  clamp(0.62rem, 1.11vw, 1.6rem)

  Layout columns (x positions in 2526px frame):
  CHANNELS col:   x=69  →  x=935  (37% of frame)
  gap:            x=935 → x=1184  (10% of frame)
  CONTACT US col: x=1184→ x=2410  (49% of frame)
  ratio ≈ 37 : 10 : 49
-->

<footer class="footer" id="contact" data-navbar-dark>

  <!-- ── Headline ── -->
  <div class="footer__headline-wrap">
    <p class="footer__headline">
      <span class="hl-white">Let's&nbsp;</span><br
      /><span class="hl-white">beg</span><span
        class="hl-muted">in a&nbsp;</span><em
        class="hl-italic">dialogue.</em>
    </p>
  </div>

  <!-- ── CHANNELS + CONTACT US ── -->
  <div class="footer__divider"></div>
  <div class="footer__main">

    <!-- col 1: CHANNELS -->
    <div class="footer__channels">
      <p class="footer__lbl">CHANNELS</p>
      <ul class="footer__ch-list">
        <li class="footer__ch-row">
          <span class="footer__ch-type">EMAIL</span>
          <a href="mailto:borsogastudio@gmail.com" class="footer__ch-val">
            borsogastudio@gmail.com
          </a>
        </li>
        <li class="footer__ch-row">
          <span class="footer__ch-type">DIRECT</span>
          <a href="tel:+17868524847" class="footer__ch-val">786-852-4847</a>
        </li>
        <li class="footer__ch-row">
          <span class="footer__ch-type">WHATS APP</span>
          <a href="https://wa.me/17868524847" target="_blank" rel="noopener"
             class="footer__ch-arrow" aria-label="WhatsApp">
            <img src={arrowSrc} alt="" class="footer__ico footer__ico--sm" />
          </a>
        </li>
      </ul>
    </div>

    <!-- col 2: gap (hidden on mobile) -->
    <div class="footer__gap"></div>

    <!-- col 3: CONTACT US + form -->
    <div class="footer__form-col">
      <p class="footer__lbl">CONTACT US</p>
      <Form client:load />
    </div>

  </div>

  <!-- ── ELSEWHERE ── -->
  <div class="footer__divider"></div>
  <div class="footer__social-row">
    <p class="footer__lbl footer__lbl--social">ELSEWHERE</p>
    <ul class="footer__social-list">
      <li>
        <a href="https://instagram.com/borsogastudio" target="_blank" rel="noopener"
           class="footer__social-link">
          INSTAGRAM
          <img src={arrowSrc} alt="" class="footer__ico footer__ico--social" />
        </a>
      </li>
      <li>
        <a href="https://linkedin.com/company/borsoga" target="_blank" rel="noopener"
           class="footer__social-link">
          LINKEDIN
          <img src={arrowSrc} alt="" class="footer__ico footer__ico--social" />
        </a>
      </li>
      <li>
        <a href="https://facebook.com/borsogastudio" target="_blank" rel="noopener"
           class="footer__social-link">
          FACEBOOK
          <img src={arrowSrc} alt="" class="footer__ico footer__ico--social" />
        </a>
      </li>
    </ul>
  </div>

  <!-- ── BOTTOM BAR ── -->
  <div class="footer__divider"></div>
  <div class="footer__bottom">
    <a href="/privacy" class="footer__bottom-txt">PRIVACY TERMS</a>
    <span class="footer__bottom-txt">EST. 2024 BORSOGA®MIAMI / GLOBAL</span>
  </div>

  <!-- ── WORDMARK ── -->
  <div class="footer__wordmark">
    <img src={wordmarkSrc} alt="BORSOGA" class="footer__wordmark-img" />
  </div>

</footer>

<style>
  /* ══ Custom properties (font scale shared with Form) ══ */
  .footer {
    --f-ch:   clamp(0.78rem, 1.43vw, 2.1rem);   /* channel / form text  36px */
    --f-lbl:  clamp(0.68rem, 1.27vw, 1.85rem);  /* dim labels           32px */
    --f-btn:  clamp(0.62rem, 1.11vw, 1.6rem);   /* send button          28px */
    --f-soc:  clamp(1.05rem, 1.90vw, 3.25rem);  /* social links         48px */
    --row-py: clamp(0.55rem, 1.1vw, 1.6rem);    /* channel row padding       */

    background: #000;
    color: #fff;
    font-family: "Poppins", sans-serif;
    padding: 0 1.04rem;
    overflow: hidden;
  }

  /* ── Headline ── */
  .footer__headline-wrap {
    padding: clamp(2rem, 4vw, 5rem) 0 clamp(1.5rem, 3vw, 4rem);
  }
  .footer__headline {
    margin: 0;
    font-size: clamp(2.4rem, 7.92vw, 13rem);
    font-weight: 600;
    line-height: 1.03;
    letter-spacing: -0.03em;
  }
  .hl-white  { color: #fff; }
  .hl-muted  { color: rgba(255,255,255,.4); }
  .hl-italic { color: rgba(255,255,255,.4); font-style: italic; font-weight: 200; }

  /* ── Divider ── */
  .footer__divider { height: 1px; background: rgba(255,255,255,.15); }

  /* ── Section label (CHANNELS / CONTACT US / ELSEWHERE) ── */
  .footer__lbl {
    margin: 0 0 clamp(0.6rem, 1.2vw, 1.8rem);
    padding-top: clamp(1rem, 2vw, 3rem);
    font-size: var(--f-lbl);
    font-weight: 500;
    color: rgba(255,255,255,.4);
    letter-spacing: .1em;
  }

  /* ══ MAIN grid: channels | gap | form ══
     Mobile: single column (gap hidden)
     ≥768px: 37fr 10fr 49fr mirroring Figma proportions               */
  .footer__main {
    display: grid;
    grid-template-columns: 1fr;
  }
  .footer__gap { display: none; }

  /* ── CHANNELS ── */
  .footer__ch-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer__ch-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: var(--row-py) 0;
    border-bottom: 1px solid rgba(255,255,255,.12);
  }
  .footer__ch-type {
    font-size: var(--f-ch);
    font-weight: 500;
    color: rgba(255,255,255,.4);
    letter-spacing: .08em;
    flex-shrink: 0;
    min-width: 7ch;
  }
  .footer__ch-val {
    font-size: var(--f-ch);
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    letter-spacing: .02em;
    transition: opacity .2s;
  }
  .footer__ch-val:hover { opacity: .6; }
  .footer__ch-arrow {
    display: flex;
    align-items: center;
    color: #fff;
    opacity: .7;
    transition: opacity .2s;
  }
  .footer__ch-arrow:hover { opacity: 1; }

  /* ── Icons ── */
  .footer__ico { display: block; flex-shrink: 0; }
  .footer__ico--sm {
    width:  var(--f-ch);
    height: var(--f-ch);
  }
  .footer__ico--social {
    width:  var(--f-soc);
    height: var(--f-soc);
    transform: rotate(90deg); /* ↘ as in Figma */
  }

  /* ══ FORM styles — inherit --f-* vars from .footer ══ */
  :global(.form-contact) {
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  :global(.form-field) {
    display: flex;
    flex-direction: column;
    padding: var(--row-py) 0;
    border-bottom: 1px solid rgba(255,255,255,.12);
    gap: clamp(0.15rem, 0.3vw, 0.5rem);
  }
  :global(.form-label) {
    font-size: var(--f-lbl);
    font-weight: 500;
    color: rgba(255,255,255,.4);
    letter-spacing: .1em;
  }
  :global(.form-input) {
    background: transparent;
    border: none;
    outline: none;
    color: #fff;
    font-family: "Poppins", sans-serif;
    font-size: var(--f-ch);
    font-weight: 500;
    letter-spacing: .02em;
    padding: 0;
    width: 100%;
  }
  :global(.form-input::placeholder) {
    color: rgba(255,255,255,.25);
    font-style: normal;
  }
  :global(.form-input--textarea) {
    resize: none;
    overflow: hidden;
    font-style: italic;
    line-height: 1.5;
  }
  :global(.form-error) {
    margin: 0;
    font-size: clamp(0.5rem, 0.9vw, 1rem);
    color: #f87171;
  }
  :global(.form-submit) {
    display: flex;
    justify-content: flex-end;
    padding-top: clamp(0.75rem, 1.5vw, 2.5rem);
  }
  :global(.form-btn) {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.4rem, 0.8vw, 1rem);
    background: #fff;
    color: #000;
    border: none;
    border-radius: 9999px;
    padding: clamp(0.45rem, 0.9vw, 1.2rem) clamp(0.9rem, 1.8vw, 2.5rem);
    font-family: "Poppins", sans-serif;
    font-size: var(--f-btn);
    font-weight: 300;
    letter-spacing: .1em;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity .2s;
  }
  :global(.form-btn:hover)    { opacity: .8; }
  :global(.form-btn:disabled) { opacity: .4; cursor: not-allowed; }

  /* ── SOCIAL ── */
  .footer__social-row {
    display: flex;
    flex-direction: column;
  }
  .footer__lbl--social { padding-bottom: 0; }
  .footer__social-list {
    list-style: none;
    margin: 0;
    padding: 0 0 clamp(1rem, 2vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1vw, 1.5rem);
  }
  .footer__social-link {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.3rem, 0.6vw, 0.9rem);
    font-size: var(--f-soc);
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    letter-spacing: .02em;
    transition: opacity .2s;
  }
  .footer__social-link:hover { opacity: .6; }

  /* ── BOTTOM BAR ── */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: .4rem;
    padding: clamp(0.75rem, 1.5vw, 2rem) 0;
  }
  .footer__bottom-txt {
    font-size: var(--f-lbl);
    font-weight: 500;
    color: rgba(255,255,255,.4);
    letter-spacing: .08em;
    text-decoration: none;
    text-transform: uppercase;
  }
  a.footer__bottom-txt:hover { color: #fff; }

  /* ── WORDMARK ── */
  .footer__wordmark { padding: clamp(0.25rem, .5vw, 1rem) 0 0; }
  .footer__wordmark-img { width: 100%; height: auto; display: block; }

  /* ══ ≥768px ══ */
  @media (min-width: 768px) {
    .footer__main {
      grid-template-columns: 37fr 10fr 49fr;
      align-items: start;
    }
    .footer__gap { display: block; }

    .footer__social-row {
      flex-direction: row;
      align-items: baseline;
      gap: clamp(2rem, 5vw, 8rem);
    }
    .footer__lbl--social {
      padding-top: clamp(1rem, 2vw, 3rem);
      flex-shrink: 0;
    }
    .footer__social-list {
      flex-direction: row;
      gap: clamp(1.5rem, 4vw, 7rem);
      padding-bottom: clamp(1rem, 2vw, 3rem);
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
