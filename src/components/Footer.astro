---
import Form from "./helpers/Form.jsx";
import wordmarkSrc from "../assets/footer-wordmark.svg?url";
import arrowSrc from "../assets/icons/right_up.svg?url";
---

<!--
  Figma frame: 2526px wide. All font sizes are expressed as fluid clamp() values
  derived from the Figma proportions: figmaSize / 2526 * 100 = vw coefficient.
  Headline:   200px → 7.92vw  → clamp(2.5rem,  7.92vw, 13rem)
  Social:      48px → 1.90vw  → clamp(1.1rem,  1.90vw,  3.5rem)
  Channels:    36px → 1.43vw  → clamp(0.85rem, 1.43vw,  2.25rem)
  Elsewhere:   32px → 1.27vw  → clamp(0.75rem, 1.27vw,  2rem)
  Send btn:    28px → 1.11vw  → clamp(0.65rem, 1.11vw,  1.75rem)
  Section lbl: 36px at 40% opacity (label above channels/contact)
-->

<footer class="footer" id="contact" data-navbar-dark>

  <!-- ── Headline ── -->
  <div class="footer__headline-wrap">
    <p class="footer__headline">
      <span class="footer__hl-white">Let's&nbsp;</span><br
      /><span class="footer__hl-white">beg</span><span
        class="footer__hl-muted">in a&nbsp;</span><em
        class="footer__hl-italic">dialogue.</em>
    </p>
  </div>

  <!-- ── CHANNELS + CONTACT US ── -->
  <div class="footer__divider"></div>
  <div class="footer__main">

    <div class="footer__channels">
      <p class="footer__section-label">CHANNELS</p>
      <ul class="footer__channel-list">
        <li class="footer__channel-item">
          <span class="footer__channel-label">EMAIL</span>
          <a href="mailto:borsogastudio@gmail.com" class="footer__channel-value">
            borsogastudio@gmail.com
          </a>
        </li>
        <li class="footer__channel-item">
          <span class="footer__channel-label">DIRECT</span>
          <a href="tel:+17868524847" class="footer__channel-value">786-852-4847</a>
        </li>
        <li class="footer__channel-item">
          <span class="footer__channel-label">WHATS APP</span>
          <a
            href="https://wa.me/17868524847"
            target="_blank"
            rel="noopener"
            class="footer__channel-arrow-link"
            aria-label="WhatsApp"
          >
            <img src={arrowSrc} alt="" class="footer__icon footer__icon--arrow" />
          </a>
        </li>
      </ul>
    </div>

    <div class="footer__form-col">
      <p class="footer__section-label">CONTACT US</p>
      <Form client:load />
    </div>

  </div>

  <!-- ── ELSEWHERE ── -->
  <div class="footer__divider"></div>
  <div class="footer__social-row">
    <p class="footer__section-label">ELSEWHERE</p>
    <ul class="footer__social-list">
      <li>
        <a href="https://instagram.com/borsogastudio" target="_blank" rel="noopener" class="footer__social-link">
          INSTAGRAM
          <img src={arrowSrc} alt="" class="footer__icon footer__icon--social" />
        </a>
      </li>
      <li>
        <a href="https://linkedin.com/company/borsoga" target="_blank" rel="noopener" class="footer__social-link">
          LINKEDIN
          <img src={arrowSrc} alt="" class="footer__icon footer__icon--social" />
        </a>
      </li>
      <li>
        <a href="https://facebook.com/borsogastudio" target="_blank" rel="noopener" class="footer__social-link">
          FACEBOOK
          <img src={arrowSrc} alt="" class="footer__icon footer__icon--social" />
        </a>
      </li>
    </ul>
  </div>

  <!-- ── BOTTOM BAR ── -->
  <div class="footer__divider"></div>
  <div class="footer__bottom">
    <a href="/privacy" class="footer__bottom-text">PRIVACY TERMS</a>
    <span class="footer__bottom-text">EST. 2024 BORSOGA®MIAMI / GLOBAL</span>
  </div>

  <!-- ── WORDMARK ── -->
  <div class="footer__wordmark">
    <img src={wordmarkSrc} alt="BORSOGA" class="footer__wordmark-img" />
  </div>

</footer>

<style>
  /* ─── Base ─── */
  .footer {
    background: #000;
    color: #fff;
    font-family: "Poppins", sans-serif;
    padding: 0 1.04rem;
    overflow: hidden;
  }

  /* ─── Headline ───
     Figma: 200px on 2526px frame → 7.92vw
     clamp: mobile floor 2.5rem, fluid 7.92vw, desktop cap 13rem          */
  .footer__headline-wrap {
    padding: clamp(2rem, 4vw, 5rem) 0 clamp(1.5rem, 3vw, 4rem);
  }
  .footer__headline {
    margin: 0;
    font-size: clamp(2.5rem, 7.92vw, 13rem);
    font-weight: 600;
    line-height: 1.03;
    letter-spacing: -0.03em;
  }
  .footer__hl-white  { color: #fff; }
  .footer__hl-muted  { color: rgba(255,255,255,0.4); }
  .footer__hl-italic {
    color: rgba(255,255,255,0.4);
    font-style: italic;
    font-weight: 200;
  }

  /* ─── Divider ─── */
  .footer__divider {
    height: 1px;
    background: rgba(255,255,255,0.15);
  }

  /* ─── Section label ───
     Figma: 36px at 40% opacity → 1.43vw
     clamp: 0.6rem … 1.43vw … 2.25rem                                     */
  .footer__section-label {
    margin: 0 0 clamp(0.75rem, 1.5vw, 2rem);
    font-size: clamp(0.6rem, 1.43vw, 2.25rem);
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.1em;
  }

  /* ─── Main grid ─── */
  .footer__main {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 5rem);
    padding: clamp(1.5rem, 3vw, 4rem) 0;
  }

  /* ─── Channels ───
     Label: same as section-label (36px → 1.43vw)
     Value: same size, full white                                           */
  .footer__channel-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer__channel-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: clamp(0.5rem, 1vw, 1.4rem) 0;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .footer__channel-label {
    font-size: clamp(0.6rem, 1.43vw, 2.25rem);
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.1em;
    min-width: 6ch;
  }
  .footer__channel-value {
    font-size: clamp(0.6rem, 1.43vw, 2.25rem);
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.2s;
  }
  .footer__channel-value:hover { opacity: 0.6; }

  .footer__channel-arrow-link {
    display: flex;
    align-items: center;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .footer__channel-arrow-link:hover { opacity: 1; }

  /* ─── Icons ─── */
  /* right_up.svg uses currentColor stroke — inherits parent color */
  .footer__icon {
    display: block;
    flex-shrink: 0;
    /* SVG has no width/height attrs — size via CSS only */
  }
  .footer__icon--arrow {
    /* WhatsApp arrow: same scale as channel text */
    width:  clamp(1rem, 1.43vw, 2.25rem);
    height: clamp(1rem, 1.43vw, 2.25rem);
  }
  .footer__icon--social {
    /* Social links arrow: scaled to social font size */
    width:  clamp(0.9rem, 1.9vw, 3rem);
    height: clamp(0.9rem, 1.9vw, 3rem);
    /* Figma shows arrow rotated 90° (pointing down-right) */
    transform: rotate(90deg);
  }

  /* ─── Social ───
     Figma: 48px → 1.90vw
     clamp: 1.1rem … 1.90vw … 3.5rem                                      */
  .footer__social-row {
    padding: clamp(1.25rem, 2.5vw, 3rem) 0;
  }
  .footer__social-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 1vw, 1.5rem);
  }
  .footer__social-link {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.4rem, 0.8vw, 1rem);
    font-size: clamp(1.1rem, 1.9vw, 3.5rem);
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.2s;
  }
  .footer__social-link:hover { opacity: 0.6; }

  /* ─── Bottom bar ───
     Figma: 32px → 1.27vw
     clamp: 0.55rem … 1.27vw … 2rem                                        */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: clamp(1rem, 2vw, 2.5rem) 0;
  }
  .footer__bottom-text {
    font-size: clamp(0.55rem, 1.27vw, 2rem);
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }
  a.footer__bottom-text:hover { color: #fff; }

  /* ─── Wordmark ─── */
  .footer__wordmark {
    padding: clamp(0.5rem, 1vw, 1.5rem) 0 0;
  }
  .footer__wordmark-img {
    /* width 100% + auto height → preserves aspect ratio, no stretching */
    width: 100%;
    height: auto;
    display: block;
  }

  /* ─── ≥768px: 2-col main, social row ─── */
  @media (min-width: 768px) {
    .footer__main {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
    .footer__social-list {
      flex-direction: row;
      gap: clamp(2rem, 4vw, 6rem);
    }
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  /* ─── ≥1280px: channels narrower, form wider ─── */
  @media (min-width: 1280px) {
    .footer__main {
      grid-template-columns: 2fr 3fr;
    }
  }
</style>
