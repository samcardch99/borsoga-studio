---
import Form from "./helpers/Form.jsx";
import wordmarkSrc from "../assets/footer-wordmark.svg?url";
import logoStacked from "../assets/logo-stacked.svg?url";

import arrowSrc from "../assets/icons/right_up.svg?url";
---

<!--
  Figma frame: 2526px wide.  Font scale: figmaPx / 2526 * 100vw
  ─────────────────────────────────────────────────────────────
  Headline:       200px → 7.92vw  clamp(2.4rem,  7.92vw, 13rem)
  Social links:    48px → 1.90vw  clamp(1.05rem, 1.90vw, 3.25rem)
  Channel text:    36px → 1.43vw  clamp(0.78rem, 1.43vw, 2.1rem)
  Elsewhere/bottom:32px → 1.27vw  clamp(0.68rem, 1.27vw, 1.85rem)
  Send btn:        28px → 1.11vw  clamp(0.62rem, 1.11vw, 1.6rem)

  Layout columns (x positions in 2526px frame):
  CHANNELS col:   x=69  →  x=935  (37% of frame)
  gap:            x=935 → x=1184  (10% of frame)
  CONTACT US col: x=1184→ x=2410  (49% of frame)
  ratio ≈ 37 : 10 : 49
-->
<footer class="footer px-10! pb-10!" id="contact" data-navbar-dark>
    <!-- ── Headline ── -->
    <div class="footer__headline-wrap">
        <p class="footer__headline" id="footer-headline">
            <span class="hl-line"
                >Let's<br class="hidden lg:block"/> begin<br class="lg:hidden"/> a <em class="hl-italic">dialogue.</em></span
            >
        </p>
    </div>

    <!-- ── CHANNELS + CONTACT US ── -->
    <div class="footer__divider"></div>
    <div class="footer__main">
        <!-- col 1: CHANNELS label -->
        <p class="footer__lbl footer__lbl--side">CHANNELS</p>

        <!-- col 2: channel list -->
        <ul class="footer__ch-list">
            <li class="footer__ch-row">
                <span class="footer__ch-type">EMAIL</span>
                <a href="mailto:info@borsogastudio.com" class="footer__ch-val">
                    info@borsogastudio.com
                </a>
            </li>
            <li class="footer__ch-row">
                <span class="footer__ch-type">DIRECT</span>
                <a href="tel:+17868524847" class="footer__ch-val"
                    >786-852-4847</a
                >
            </li>
            <li class="footer__ch-row footer__ch-row--arrow">
                <span class="footer__ch-type">WHATS APP</span>
                <a
                    href="https://wa.me/17868524847"
                    target="_blank"
                    rel="noopener"
                    class="footer__ch-arrow"
                    aria-label="WhatsApp"
                >
                    <img
                        src={arrowSrc}
                        alt=""
                        class="footer__ico footer__ico--sm"
                    />
                </a>
            </li>
        </ul>

        <!-- col 3: gap -->
        <div class="footer__gap"></div>

        <!-- col 4: CONTACT US label -->
        <p class="footer__lbl footer__lbl--side">CONTACT US</p>

        <!-- col 5: form -->
        <div class="footer__form-col">
            <Form client:load />
        </div>
    </div>

    <!-- ── ELSEWHERE ── -->
    <div class="footer__divider"></div>
    <div class="footer__social-row">
        <p class="footer__lbl footer__lbl--social">ELSEWHERE</p>
        <ul class="footer__social-list">
            <li>
                <a
                    href="https://instagram.com/borsogastudio"
                    target="_blank"
                    rel="noopener"
                    class="footer__social-link"
                >
                    INSTAGRAM
                    <img
                        src={arrowSrc}
                        alt=""
                        class="footer__ico footer__ico--social"
                    />
                </a>
            </li>
            <li>
                <a
                    href="https://linkedin.com/company/borsogastudio"
                    target="_blank"
                    rel="noopener"
                    class="footer__social-link"
                >
                    LINKEDIN
                    <img
                        src={arrowSrc}
                        alt=""
                        class="footer__ico footer__ico--social"
                    />
                </a>
            </li>
            <li>
                <a
                    href="https://www.facebook.com/profile.php?id=61581895641990&mibextid=wwXIfr&rdid=cFBjveOl7j3c14R5&share_url=https%3A%2F%2Fwww.facebook.com%2Fshare%2F1T36eTNSSr%2F%3Fmibextid%3DwwXIfr%26ref%3D1#git "
                    target="_blank"
                    rel="noopener"
                    class="footer__social-link"
                >
                    FACEBOOK
                    <img
                        src={arrowSrc}
                        alt=""
                        class="footer__ico footer__ico--social"
                    />
                </a>
            </li>
        </ul>
    </div>

    <!-- ── BOTTOM BAR ── -->
    <div class="footer__divider"></div>
    <div class="footer__bottom">
        <a href="/privacy" class="footer__bottom-txt">PRIVACY TERMS</a>
        <span class="footer__bottom-txt">EST. 2026 BORSOGA®STUDIO / GLOBAL</span
        >
    </div>

     <!-- ── WORDMARK ── -->
    <div class="footer__wordmark md:hidden block">
        <img src={logoStacked} alt="BORSOGA" class="footer__wordmark-img" />
    </div>
    <!-- ── WORDMARK ── -->
    <div class="footer__wordmark hidden md:block">
        <img src={wordmarkSrc} alt="BORSOGA" class="footer__wordmark-img" />
    </div>
</footer>

<style>
    /* ══ Custom properties (font scale shared with Form) ══ */
    .footer {
        --f-ch: clamp(0.85rem, 1.25vw, 1.8rem); /* channel val / form input */
        --f-lbl: clamp(0.65rem, 0.85vw, 1.2rem); /* dim labels */
        --f-btn: 1.25rem; /* send button — matches navbar CTA (desktop) */
        --f-soc: clamp(1rem, 1.5vw, 2.2rem); /* social links */
        --row-py: clamp(0.55rem, 1.1vw, 1.6rem); /* channel row padding */

        background: #000;
        color: #fff;
        font-family: "Poppins", sans-serif;
        padding: 0 1.04rem;
        overflow: hidden;
    }

    /* ── Headline ── */
    .footer__headline-wrap {
        padding: clamp(2rem, 4vw, 5rem) 0 clamp(1.5rem, 3vw, 4rem);
    }
    .footer__headline {
        margin: 0;
        font-size: clamp(2.4rem, 7.92vw, 13rem);
        font-weight: 600;
        line-height: 1.03;
        letter-spacing: -0.03em;
    }
    .hl-line {
        display: block;
    }
    .hl-italic {
        font-style: italic;
        font-weight: 200;
    }

    /* ── Divider ── */
    .footer__divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.15);
    }

    /* ── Section label (CHANNELS / CONTACT US / ELSEWHERE) ── */
    .footer__lbl {
        margin: 0 0 clamp(0.6rem, 1.2vw, 1.8rem);
        padding-top: clamp(1rem, 2vw, 3rem);
        font-size: var(--f-lbl);
        font-weight: 500;
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 0.1em;
    }

    /* ══ MAIN grid ══
     Mobile: single column (labels block, gap hidden)
     ≥768px: label | channels | gap | label | form               */
    .footer__main {
        display: grid;
        grid-template-columns: 1fr;
    }
    .footer__gap {
        display: none;
    }
    .footer__lbl--side {
        display: block;
        margin-bottom: 0;
    }

    /* ── CHANNELS ── */
    .footer__ch-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    .footer__ch-row {
        display: flex;
        align-items: center;
        gap: clamp(1rem, 2.5vw, 4rem);
        padding: var(--row-py) 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }
    .footer__ch-row--arrow {
        justify-content: space-between;
    }
    .footer__ch-type {
        font-size: var(--f-ch);
        font-weight: 500;
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 0.08em;
        flex-shrink: 0;
        min-width: 8ch;
    }
    .footer__ch-val {
        font-size: var(--f-ch);
        font-weight: 500;
        color: #fff;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: opacity 0.2s;
    }
    .footer__ch-val:hover {
        opacity: 0.6;
    }
    .footer__ch-arrow {
        display: flex;
        align-items: center;
        color: #fff;
        opacity: 0.7;
        transition: opacity 0.2s;
    }
    .footer__ch-arrow:hover {
        opacity: 1;
    }

    /* ── Icons ── */
    .footer__ico {
        display: block;
        flex-shrink: 0;
        filter: invert(1);
    }
    .footer__ico--sm {
        width: var(--f-ch);
        height: var(--f-ch);
    }
    .footer__ico--social {
        width: var(--f-soc);
        height: var(--f-soc);
        transform: rotate(90deg); /* ↘ as in Figma */
    }

    /* ══ FORM styles — inherit --f-* vars from .footer ══ */
    :global(.form-contact) {
        width: 100%;
        display: flex;
        flex-direction: column;
    }
    :global(.form-field) {
        display: flex;
        flex-direction: column;
        padding: var(--row-py) 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        gap: clamp(0.15rem, 0.3vw, 0.5rem);
    }
    :global(.form-label) {
        font-size: var(--f-lbl);
        font-weight: 500;
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 0.1em;
    }
    :global(.form-input) {
        background: transparent;
        border: none;
        outline: none;
        color: #fff;
        font-family: "Poppins", sans-serif;
        font-size: var(--f-ch);
        font-weight: 600;
        letter-spacing: 0.02em;
        padding: 0;
        width: 100%;
    }
    :global(.form-input::placeholder) {
        color: rgba(255, 255, 255, 0.25);
        font-style: normal;
        font-weight: 400;
    }
    :global(.form-input--textarea::placeholder) {
        font-style: italic;
    }
    :global(.form-input--textarea) {
        resize: none;
        overflow: hidden;
        font-style: italic;
        line-height: 1.5;
    }
    :global(.form-error) {
        margin: 0;
        font-size: clamp(0.5rem, 0.9vw, 1rem);
        color: #f87171;
    }
    :global(.form-submit) {
        display: flex;
        justify-content: flex-end;
       
    }
    :global(.form-btn) {
        display: inline-flex;
        align-items: center;
        gap: clamp(0.4rem, 0.8vw, 1rem);
        background: #fff;
        color: #000;
        border: none;
        border-radius: 9999px;
        padding: 0.75rem 1.5rem;
        font-family: "Poppins", sans-serif;
        font-size: var(--f-btn);
        font-weight: 300;
        letter-spacing: 0.1em;
        cursor: pointer;
        white-space: nowrap;
        transition: opacity 0.2s;
    }
    :global(.form-btn:hover) {
        opacity: 0.8;
    }
    :global(.form-btn:disabled) {
        opacity: 0.4;
        cursor: not-allowed;
    }

    /* ── SOCIAL ── */
    .footer__social-row {
        display: flex;
        flex-direction: column;
    }
    .footer__lbl--social {
        padding-bottom: 0;
    }
    .footer__social-list {
        list-style: none;
        margin: 0;
        padding: 0 0 clamp(1rem, 2vw, 3rem);
        display: flex;
        flex-direction: column;
        gap: clamp(0.5rem, 1vw, 1.5rem);
    }
    .footer__social-link {
        display: inline-flex;
        align-items: center;
        gap: clamp(0.3rem, 0.6vw, 0.9rem);
        font-size: var(--f-soc);
        font-weight: 500;
        color: #fff;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: opacity 0.2s;
    }
    .footer__social-link:hover {
        opacity: 0.6;
    }

    /* ── BOTTOM BAR ── */
    .footer__bottom {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        padding: clamp(0.75rem, 1.5vw, 2rem) 0;
    }
    .footer__bottom-txt {
        font-size: var(--f-lbl);
        font-weight: 500;
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 0.08em;
        text-decoration: none;
        text-transform: uppercase;
    }
    a.footer__bottom-txt:hover {
        color: #fff;
    }

    /* ── WORDMARK ── */
    .footer__wordmark {
        padding: clamp(0.25rem, 0.5vw, 1rem) 0 0;
    }
    .footer__wordmark-img {
        width: 100%;
        height: auto;
        display: block;
    }

    /* ══ MOBILE & TABLET (≤1024px) — single column stack (Figma) ══
       Figma mobile (591px frame): headline 96px, body 20px (labels = values),
       social 36px. Loose vertical rhythm so the sections aren't cramped. */
    @media (max-width: 1024px) {
        .footer {
            --f-ch: clamp(1.4rem, 3.6vw, 2.1rem); /* channel value / form input */
            --f-lbl: clamp(1.3rem, 3.2vw, 1.9rem); /* labels (≈ values, dimmed) */
            --f-soc: clamp(2.2rem, 6vw, 3.2rem); /* social links (36px) */
            --f-btn: 1rem; /* send button — matches navbar CTA (mobile) */
            --row-py: clamp(1.5rem, 4vw, 2.4rem); /* taller channel / form rows */
        }
        /* Send button padding — matches navbar CTA (mobile) */
        :global(.form-btn) {
            padding: 0.6rem 1.4rem;
        }
        /* Headline — larger, flows & wraps naturally (like Figma), with air */
        .footer__headline {
            font-size: clamp(4rem, 14vw, 8.5rem);
        }
        .hl-line {
            display: inline;
        }
        .footer__headline-wrap {
            padding: clamp(3rem, 8vw, 6rem) 0 clamp(3rem, 7vw, 5rem);
        }
        /* generous gap above each section label (CHANNELS / CONTACT US / ELSEWHERE) */
        .footer__lbl {
            padding-top: clamp(3.6rem, 9.5vw, 6.5rem);
            margin-bottom: clamp(1.4rem, 3.4vw, 2.2rem);
        }
        /* channel rows: label left, value pushed to the right edge */
        .footer__ch-row {
            justify-content: space-between;
            gap: 1.2rem;
        }
        .footer__ch-type {
            min-width: 0;
        }
        .footer__ch-val {
            text-align: right;
        }
        /* ELSEWHERE: links centred & generously spaced */
        .footer__lbl--social {
            padding-bottom: clamp(2.4rem, 6vw, 4rem);
        }
        .footer__social-list {
            align-items: center;
            gap: clamp(2.6rem, 7vw, 4.5rem);
            padding-bottom: clamp(3rem, 7vw, 5rem);
        }
        .footer__social-link {
            justify-content: center;
        }
        /* bottom bar + wordmark breathing room */
        .footer__bottom {
            padding: clamp(2.4rem, 6vw, 4rem) 0;
            gap: 0.9rem;
        }
        .footer__wordmark {
            padding-top: clamp(1.6rem, 4vw, 3rem);
        }
    }

    /* Tablet (768–1024px): match navbar "BEGIN A DIALOGUE" CTA size. */
    @media (min-width: 768px) and (max-width: 1024px) {
        .footer { --f-btn: 1.3rem; }
        :global(.form-btn) { padding: 0.8rem 1.8rem; }
    }

    /* ══ ≥1025px (desktop) ══ */
    @media (min-width: 1025px) {
        /* label-ch | channels | gap | label-cu | form
           Figma x positions (2526px frame):
           CHANNELS label: ~69px wide ≈ 3fr
           channels list:  69→935 minus label ≈ 34fr
           gap:            935→1184 ≈ 10fr
           CONTACT US lbl: ~120px ≈ 5fr
           form:           1184→2410 minus label ≈ 44fr          */
        .footer__main {
            grid-template-columns: auto 1fr clamp(2rem, 8vw, 8rem) auto 1fr;
            align-items: start;
            column-gap: 0;
        }
        .footer__gap {
            display: block;
        }
        .footer__lbl--side {
            padding-top: var(--row-py);
            padding-right: clamp(1rem, 2vw, 3rem);
            white-space: nowrap;
        }
        /* CONTACT US label gets extra left padding (gap col handles spacing) */
        .footer__lbl--side + .footer__form-col {
            padding-top: 0;
        }

        .footer__social-row {
            flex-direction: row;
            align-items: baseline;
            gap: clamp(1.5rem, 3vw, 5rem);
        }
        .footer__lbl--social {
            padding-top: clamp(1rem, 2vw, 3rem);
            flex-shrink: 0;
        }
        .footer__social-list {
            flex-direction: row;
            justify-content: space-between;
            padding-bottom: clamp(1rem, 2vw, 3rem);
            flex: 1;
        }

        .footer__bottom {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
    }

    #footer-headline .char {
        display: inline-block;
        color: rgba(255, 255, 255, 0.19);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { SplitText } from "gsap/SplitText";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(SplitText, ScrollTrigger);

    const headline = document.getElementById("footer-headline");
    const split = new SplitText(headline, {
        type: "chars",
        charsClass: "char",
    });

    gsap.set(split.chars, { color: "rgba(255,255,255,0.19)" });

    gsap.to(split.chars, {
        color: "white",
        duration: 0.1,
        stagger: { each: 0.07, from: "start" },
        ease: "none",
        scrollTrigger: {
            trigger: headline,
            start: "top 85%",
        },
    });
</script>
