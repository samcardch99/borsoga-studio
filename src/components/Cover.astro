---
import RightUpArrow from "../assets/icons/right_up.svg";
import DecorSpiral from "../assets/decor-spiral.svg";
---

<!--
  Unidades rem calibradas para 1440px HD (1rem = 10px).
  El root font-size escala en global.css a 17.78px en 2K y 26.67px en 4K,
  por lo que todos los rem del componente se reescalan proporcionalmente
  sin cambiar ninguna clase aquí.
-->
<section
  data-navbar-dark
  class="relative w-full h-svh min-h-[600px] bg-black text-white font-poppins overflow-hidden flex flex-col"
>
  <!-- Decorative breathing spiral — top-right corner -->
  <DecorSpiral class="cover-spiral" aria-hidden="true" />

  <!-- Main content -->
  <div
    class="relative z-10 flex-1 grid grid-cols-1 md:grid-cols-2 px-[4rem] pt-[2vh] pb-[7vh] gap-[3rem]"
  >
    <!-- Left: location + headline -->
    <div class="flex flex-col justify-center pb-[3vh]">
      <!-- location: 1.4rem (14px en HD) -->
      <p class="m-0 mb-[1.5rem] font-light text-[1.4rem] tracking-[0.01em]">
        [ Borsoga Studio · Miami, FL · Working globally ]
      </p>
      <!-- headline: 9rem (90px en HD · 160px en 2K · 240px en 4K) -->
      <h1
        id="cover-h1"
        class="m-0 font-semibold text-[9rem] leading-[1.13] text-white/19"
      >
        <span>Digital spaces</span><span
          >for the <em class="font-extralight italic">unbuilt</em><br
          />imagination.</span
        >
      </h1>
    </div>

    <!-- Right: description + CTA -->
    <div class="flex items-start md:items-end justify-center gap-8">
      <div class="flex items-center justify-center h-fit w-full">
        <!-- description: 1.4rem, max-w 46rem (460px en HD · 818px en 2K · 1227px en 4K) -->
        <p
          class="m-0 font-light text-[1.4rem] leading-[1.9] text-left max-w-184"
        >
          We combine 3D visualization, immersive environments, custom web
          platforms, and brand identity to translate concepts into absolute
          visual clarity.
        </p>
        <a
          href="#work"
          class="inline-flex items-center gap-2 no-underline font-light text-xl py-4 px-6 rounded-full whitespace-nowrap tracking-wider transition-opacity duration-200 hover:opacity-90 bg-white text-black"
        >
          VIEW OUR WORK
          <RightUpArrow class="h-8 aspect-square" />
        </a>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div
      class="absolute bottom-[3vh] left-1/2 -translate-x-1/2 z-10 flex items-center gap-[1.2rem]"
    >
      <span class="font-light text-[1rem] tracking-[0.15em]">SCROLL</span>
      <div class="relative h-[5vh] w-px bg-white/30 overflow-visible">
        <div
          class="scroll-dot absolute left-1/2 w-[0.8rem] h-[0.8rem] bg-white rounded-full -translate-x-1/2"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Decorative spiral — top-right corner, behind the content ── */
  .cover-spiral {
    position: absolute;
    top: 0rem;
    right: 0rem;
    width: clamp(40rem, 48vw, 70rem);
    height: auto;
    z-index: 110; /* sobre el banner del navbar (z-100) */
    opacity: 0.9;
    pointer-events: none;
    transform-origin: center center;
    will-change: transform, opacity;
  }

  @keyframes scroll-dot {
    0% {
      top: -0.4rem;
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    80% {
      opacity: 1;
    }
    100% {
      top: 5vh;
      opacity: 0;
    }
  }

  .scroll-dot {
    animation: scroll-dot 1.8s cubic-bezier(0.45, 0, 0.55, 1) infinite;
  }

  /* Chars start at white/19 and animate to full white via GSAP */
  #cover-h1 .char {
    color: rgba(255, 255, 255, 0.19);
    display: inline-block;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(SplitText);

  const h1 = document.getElementById("cover-h1");
  const split = new SplitText(h1, { type: "chars", charsClass: "char" });

  gsap.to(split.chars, {
    color: "white",
    duration: 0.1,
    stagger: {
      each: 0.07,
      from: "start",
    },
    ease: "none",
    delay: 0.3,
  });

  // ── Heartbeat spiral ──────────────────────────────────────────────
  // The concentric lines (paths) expand & contract about the spiral's
  // centre — a slow, smooth heartbeat that gives life to the cover.
  // No rotation; the strokes themselves breathe.
  const spiral = document.querySelector(".cover-spiral");
  if (spiral) {
    const paths = spiral.querySelectorAll("path");

    // Pole ≈ centre of the innermost (smallest) ring → all lines scale
    // about this single point, so they fan outward and back in.
    let cx = 745, cy = 618;
    const boxes = Array.from(paths, (p) => (p as SVGGraphicsElement).getBBox());
    if (boxes.length) {
      let inner = boxes[0];
      for (const b of boxes)
        if (b.width * b.height < inner.width * inner.height) inner = b;
      cx = inner.x + inner.width / 2;
      cy = inner.y + inner.height / 2;
    }

    // The beat: lines expand and contract (sine ease, yoyo loop).
    gsap.to(paths, {
      scale: 1.07,
      svgOrigin: `${cx} ${cy}`,
      duration: 2,
      ease: "sine.inOut",
      repeat: -1,
      yoyo: true,
    });

    // Cinematic sweep: a highlight travels line-by-line across the spiral.
    // Each path dims to a base, then a staggered opacity wave lights them up
    // one after another — a scanning glow that layers over the heartbeat.
    gsap.set(paths, { opacity: 0.2 });
    gsap.to(paths, {
      opacity: 1,
      duration: 0.45,      // tighter band → fewer lines lit at once
      ease: "sine.inOut",
      stagger: {
        each: 0.2,
        from: "end",       // sweep from the bright inner ring outward
        repeat: -1,
        yoyo: true,
        repeatDelay: 2,    // each line waits before re-lighting, so one
                           // sweep clears before the next starts (less overlap)
      },
    });
  }
</script>
