---
import logoSrc from "../../assets/logo.svg?url";
import logoStackedSrc from "../../assets/logo-stacked.svg?url";
import RightUpArrow from "../../assets/icons/right_up.svg";
---

<nav id="interior-nav" class="interior-nav fixed top-0 left-0 z-100 w-full flex items-center justify-between px-[2.4rem] md:px-[4.2rem] lg:px-16 py-[2vh]">
  <a href="/" aria-label="Borsoga Studio">
    <!-- stacked mark on mobile only; horizontal wordmark from tablet up -->
    <img
      src={logoStackedSrc}
      alt="Borsoga Studio"
      class="interior-nav__logo block md:hidden h-[3.8rem] w-auto"
    />
    <img
      src={logoSrc}
      alt="Borsoga Studio"
      class="interior-nav__logo hidden md:block h-[3rem] lg:h-[3.8rem] w-auto"
    />
  </a>

  <ul class="absolute left-1/2 -translate-x-1/2 hidden md:flex gap-8 lg:gap-16 list-none m-0 p-0">
    <li>
      <a href="/#work" class="interior-nav__link no-underline font-bold text-[1.2rem] lg:text-[1.4rem] tracking-[0.02em] transition-opacity duration-300 hover:opacity-60">
        Work
      </a>
    </li>
    <li>
      <a href="/#categories" class="interior-nav__link no-underline font-bold text-[1.2rem] lg:text-[1.4rem] tracking-[0.02em] transition-opacity duration-300 hover:opacity-60">
        Capabilities
      </a>
    </li>
    <li>
      <a href="/#contact" class="interior-nav__link no-underline font-bold text-[1.2rem] lg:text-[1.4rem] tracking-[0.02em] transition-opacity duration-300 hover:opacity-60">
        Contact
      </a>
    </li>
  </ul>

  <a
    href="/#contact"
    class="inline-flex items-center gap-1 md:gap-2 no-underline font-light text-[1rem] md:text-[1.3rem] lg:text-[1.25rem] py-[0.6rem] px-[1.4rem] md:py-[0.8rem] md:px-[1.8rem] lg:py-3 lg:px-6 rounded-full whitespace-nowrap tracking-wider transition-opacity duration-200 hover:opacity-90 bg-black text-white"
  >
    BEGIN A DIALOGUE
    <RightUpArrow class="h-[1.1rem] md:h-[1.3rem] lg:h-[1.6rem]" />
  </a>
</nav>

<style>
  .interior-nav {
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 0.5px solid rgba(0, 0, 0, 0.09);
    transform: translateY(0);
    transition: transform 0.38s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  /* Slide out of viewport when scrolling down */
  .interior-nav.is-hidden {
    transform: translateY(-100%);
  }

  /* Always dark — logo inverted to black, links black */
  .interior-nav__logo {
    filter: invert(1);
    transition: opacity 0.2s;
  }
  .interior-nav__logo:hover {
    opacity: 0.65;
  }

  .interior-nav__link {
    color: #000;
  }
</style>

<script>
  function initInteriorNav() {
    const nav = document.getElementById("interior-nav");
    if (!nav) return;

    let lastY = window.scrollY;
    let ticking = false;

    /* Small dead-zone at the very top — never hide within first navH px */
    const getNavH = () => nav.offsetHeight;

    function update(y: number) {
      const navH = getNavH();

      if (y > lastY && y > navH) {
        /* Scrolling down — hide */
        nav!.classList.add("is-hidden");
      } else {
        /* Scrolling up or near top — show */
        nav!.classList.remove("is-hidden");
      }
      lastY = y;
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update(window.scrollY);
        ticking = false;
      });
    }

    /* Single scroll source — Lenis emits its own native `scroll` events too,
       so binding BOTH window-scroll and lenis.on("scroll") makes two paths
       mutate the shared `lastY` out of sync → the nav flickers hide/show.
       Prefer Lenis when present; otherwise fall back to native scroll. */
    const lenis = (window as any).lenis;
    if (lenis) {
      lenis.on("scroll", ({ scroll }: { scroll: number }) => {
        update(scroll);
      });
    } else {
      window.addEventListener("scroll", onScroll, { passive: true });
    }
  }

  document.addEventListener("astro:page-load", initInteriorNav);
  if (document.readyState !== "loading") initInteriorNav();
  else document.addEventListener("DOMContentLoaded", initInteriorNav);
</script>
